# These environment variables are needed to run the app locally.
# Copy these into a file named .env.development to have them loaded automatically.

MCP_API_KEY=test-key-123

# SeaweedFS S3 (Active Storage backend) -- start with: bin/cli storage start
SEAWEEDFS_ENDPOINT=https://storage.workeverywhere.docker
SEAWEEDFS_ACCESS_KEY_ID=any
SEAWEEDFS_SECRET_ACCESS_KEY=any
SEAWEEDFS_BUCKET=catalyst
