{"screenId":"b7de30c1d955452c9b720ad0a84d5c9d","projectId":"3314239195447065678","htmlContent":"<!DOCTYPE html>\n\n<html lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"tertiary\": \"#855300\",\n              \"inverse-on-surface\": \"#eef0ff\",\n              \"surface-container-low\": \"#f2f3ff\",\n              \"surface\": \"#faf8ff\",\n              \"secondary-fixed-dim\": \"#45dfa4\",\n              \"on-primary-container\": \"#004965\",\n              \"on-tertiary-fixed\": \"#2a1700\",\n              \"on-error\": \"#ffffff\",\n              \"primary-fixed\": \"#c4e7ff\",\n              \"outline\": \"#6e7980\",\n              \"secondary\": \"#006c4b\",\n              \"inverse-primary\": \"#7bd0ff\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"surface-container-high\": \"#e2e7ff\",\n              \"primary\": \"#00668a\",\n              \"surface-container\": \"#eaedff\",\n              \"background\": \"#faf8ff\",\n              \"surface-dim\": \"#d2d9f4\",\n              \"on-surface-variant\": \"#3e484f\",\n              \"secondary-fixed\": \"#68fcbf\",\n              \"on-secondary-fixed-variant\": \"#005137\",\n              \"inverse-surface\": \"#283044\",\n              \"error-container\": \"#ffdad6\",\n              \"on-primary-fixed-variant\": \"#004c69\",\n              \"primary-container\": \"#38bdf8\",\n              \"on-surface\": \"#131b2e\",\n              \"outline-variant\": \"#bdc8d1\",\n              \"on-tertiary\": \"#ffffff\",\n              \"surface-container-highest\": \"#dae2fd\",\n              \"on-background\": \"#131b2e\",\n              \"secondary-container\": \"#64f9bc\",\n              \"on-secondary-fixed\": \"#002114\",\n              \"on-secondary-container\": \"#00714e\",\n              \"surface-variant\": \"#dae2fd\",\n              \"tertiary-fixed\": \"#ffddb8\",\n              \"on-secondary\": \"#ffffff\",\n              \"tertiary-container\": \"#f1a02b\",\n              \"on-primary\": \"#ffffff\",\n              \"tertiary-fixed-dim\": \"#ffb960\",\n              \"surface-bright\": \"#faf8ff\",\n              \"on-tertiary-fixed-variant\": \"#653e00\",\n              \"error\": \"#ba1a1a\",\n              \"surface-tint\": \"#00668a\",\n              \"on-error-container\": \"#93000a\",\n              \"primary-fixed-dim\": \"#7bd0ff\",\n              \"on-primary-fixed\": \"#001e2c\",\n              \"on-tertiary-container\": \"#613b00\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Inter\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"1rem\", \"lg\": \"2rem\", \"xl\": \"3rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .tonal-sculpting {\n            background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(242,243,255,1) 100%);\n        }\n        .aura-shadow {\n            box-shadow: 0 20px 40px -12px rgba(19, 27, 46, 0.08);\n        }\n        /* Navigation Drawer styles */\n        #nav-drawer {\n            transform: translateX(-100%);\n            transition: transform 0.3s ease-in-out;\n        }\n        #nav-drawer.open {\n            transform: translateX(0);\n        }\n        #nav-overlay {\n            opacity: 0;\n            pointer-events: none;\n            transition: opacity 0.3s ease-in-out;\n        }\n        #nav-overlay.open {\n            opacity: 1;\n            pointer-events: auto;\n        }\n    </style>\n</head>\n<body class=\"bg-background text-on-background font-body antialiased overflow-x-hidden\">\n<!-- Navigation Drawer Overlay -->\n<div class=\"fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[60]\" id=\"nav-overlay\" onclick=\"toggleDrawer()\"></div>\n<!-- Navigation Drawer -->\n<aside class=\"fixed top-0 left-0 h-full w-[280px] bg-white dark:bg-slate-900 z-[70] shadow-2xl flex flex-col p-6\" id=\"nav-drawer\">\n<div class=\"flex items-center gap-4 mb-10\">\n<h1 class=\"font-['Space_Grotesk'] font-bold tracking-tight text-2xl text-slate-900 dark:text-slate-50\">Catalyst</h1>\n<button class=\"ml-auto p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors\" onclick=\"toggleDrawer()\">\n<span class=\"material-symbols-outlined text-slate-500\">close</span>\n</button>\n</div>\n<nav class=\"flex flex-col gap-2\">\n<a class=\"flex items-center gap-4 p-4 rounded-xl hover:bg-sky-50 dark:hover:bg-sky-900/20 text-slate-600 dark:text-slate-400 hover:text-sky-500 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">home</span>\n<span class=\"font-semibold\">Home</span>\n</a>\n<a class=\"flex items-center gap-4 p-4 rounded-xl bg-sky-50 dark:bg-sky-900/20 text-sky-500 font-bold transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">explore</span>\n<span>Trips</span>\n</a>\n<a class=\"flex items-center gap-4 p-4 rounded-xl hover:bg-sky-50 dark:hover:bg-sky-900/20 text-slate-600 dark:text-slate-400 hover:text-sky-500 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">edit_note</span>\n<span class=\"font-semibold\">Journal</span>\n</a>\n<div class=\"h-px bg-slate-100 dark:bg-slate-800 my-4\"></div>\n<a class=\"flex items-center gap-4 p-4 rounded-xl hover:bg-sky-50 dark:hover:bg-sky-900/20 text-slate-600 dark:text-slate-400 hover:text-sky-500 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">settings</span>\n<span class=\"font-semibold\">Settings</span>\n</a>\n</nav>\n<div class=\"mt-auto p-4 bg-slate-50 dark:bg-slate-800/50 rounded-2xl flex items-center gap-3\">\n<div class=\"w-10 h-10 rounded-full overflow-hidden border border-outline-variant/30\">\n<img alt=\"User profile avatar\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCCxOFN6kdlhHdKvmHq9Kogd4UmgausG6c07JsLar_FhegxCq4Gt_oYO-KVLCzUSlKySKtcR-EOEus9F63rrOzqLX7ZgBL1RHV3AEm8mTBNlNxROYpiySC688_kg6_Uh7CBxXrrwzaTuUgogYd9tngY7iETA9Jx-9PVSpuU1GCUuyh4kR-At07OOFYdx9Aqbp1SazyQdEhB4djoOxRLuZtbSIHoQuaJxUZMRd_y5SipMcLFmXRooKt6vGXw1ZfcZsG5Aj0gdlZUE9Y\"/>\n</div>\n<div>\n<p class=\"text-sm font-bold text-on-surface\">Alex River</p>\n<p class=\"text-xs text-on-surface-variant\">Pro Explorer</p>\n</div>\n</div>\n</aside>\n<!-- TopAppBar -->\n<header class=\"fixed top-0 w-full z-50 bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl border-b border-white/30 dark:border-slate-800/50 shadow-sm dark:shadow-none flex justify-between items-center px-6 h-16\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-slate-700 dark:text-slate-200 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-800 p-2 rounded-full transition-all active:scale-95 duration-200\" onclick=\"toggleDrawer()\">menu</span>\n<h1 class=\"font-['Space_Grotesk'] font-bold tracking-tight text-xl text-slate-900 dark:text-slate-50\">Catalyst</h1>\n</div>\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-slate-500 hover:text-sky-500 transition-colors cursor-pointer\">search</span>\n<div class=\"w-8 h-8 rounded-full overflow-hidden border border-outline-variant/30\">\n<img alt=\"User profile avatar\" data-alt=\"Close-up portrait of a stylish man with a warm smile, soft natural lighting, editorial photography style\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCCxOFN6kdlhHdKvmHq9Kogd4UmgausG6c07JsLar_FhegxCq4Gt_oYO-KVLCzUSlKySKtcR-EOEus9F63rrOzqLX7ZgBL1RHV3AEm8mTBNlNxROYpiySC688_kg6_Uh7CBxXrrwzaTuUgogYd9tngY7iETA9Jx-9PVSpuU1GCUuyh4kR-At07OOFYdx9Aqbp1SazyQdEhB4djoOxRLuZtbSIHoQuaJxUZMRd_y5SipMcLFmXRooKt6vGXw1ZfcZsG5Aj0gdlZUE9Y\"/>\n</div>\n</div>\n</header>\n<main class=\"pt-24 pb-32 px-6 max-w-5xl mx-auto min-h-screen\">\n<!-- Hero Header -->\n<div class=\"mb-12\">\n<span class=\"font-label text-primary font-bold tracking-widest text-xs uppercase mb-2 block\">Preparation</span>\n<h2 class=\"font-headline text-5xl font-bold tracking-tighter text-on-surface mb-4\">Trip Checklist</h2>\n<p class=\"text-on-surface-variant max-w-xl text-lg leading-relaxed\">Ensure every detail of your journey is curated to perfection. From essential documents to personal comfort.</p>\n</div>\n<!-- Checklist Grid -->\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 items-start\">\n<!-- Section: Packing List -->\n<section class=\"bg-surface-container-lowest rounded-lg aura-shadow p-8 flex flex-col gap-6\">\n<div class=\"flex items-center justify-between\">\n<div class=\"flex items-center gap-3\">\n<div class=\"p-2 bg-primary-container/20 rounded-full\">\n<span class=\"material-symbols-outlined text-primary\">inventory_2</span>\n</div>\n<h3 class=\"font-headline text-xl font-bold text-on-surface\">Packing List</h3>\n</div>\n<span class=\"font-label text-xs font-semibold text-primary bg-primary-container/10 px-3 py-1 rounded-full\">4/12 Items</span>\n</div>\n<div class=\"flex flex-col gap-1\">\n<!-- Checklist Item -->\n<div class=\"group flex items-center justify-between p-3 rounded-xl hover:bg-surface-container-low transition-all duration-300\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-6 h-6 rounded-md border-2 border-primary-container flex items-center justify-center cursor-pointer bg-primary-container\" style=\"font-variation-settings: 'FILL' 1;\">\n<span class=\"material-symbols-outlined text-white text-sm\">check</span>\n</div>\n<span class=\"text-on-surface-variant line-through opacity-60\">Weatherproof Shell Jacket</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant opacity-0 group-hover:opacity-100 hover:text-error transition-all cursor-pointer text-xl\">delete</span>\n</div>\n<div class=\"group flex items-center justify-between p-3 rounded-xl hover:bg-surface-container-low transition-all duration-300\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-6 h-6 rounded-md border-2 border-outline-variant flex items-center justify-center cursor-pointer hover:border-primary transition-colors\"></div>\n<span class=\"text-on-surface\">Merino Wool Base Layers</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant opacity-0 group-hover:opacity-100 hover:text-error transition-all cursor-pointer text-xl\">delete</span>\n</div>\n<div class=\"group flex items-center justify-between p-3 rounded-xl hover:bg-surface-container-low transition-all duration-300\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-6 h-6 rounded-md border-2 border-outline-variant flex items-center justify-center cursor-pointer hover:border-primary transition-colors\"></div>\n<span class=\"text-on-surface\">Compact First Aid Kit</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant opacity-0 group-hover:opacity-100 hover:text-error transition-all cursor-pointer text-xl\">delete</span>\n</div>\n</div>\n<!-- Add New Item -->\n<div class=\"mt-4 pt-6 border-t border-surface-container\">\n<div class=\"relative group\">\n<input class=\"w-full bg-surface-container-highest border-none rounded-md px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 transition-all placeholder:text-outline-variant\" placeholder=\"Add New Item...\" type=\"text\"/>\n<button class=\"absolute right-2 top-1.5 p-1.5 bg-primary text-white rounded-md opacity-0 group-focus-within:opacity-100 transition-opacity\">\n<span class=\"material-symbols-outlined text-sm\">add</span>\n</button>\n</div>\n</div>\n</section>\n<!-- Section: Documents -->\n<section class=\"bg-surface-container-lowest rounded-lg aura-shadow p-8 flex flex-col gap-6\">\n<div class=\"flex items-center justify-between\">\n<div class=\"flex items-center gap-3\">\n<div class=\"p-2 bg-tertiary-container/20 rounded-full\">\n<span class=\"material-symbols-outlined text-tertiary-container\" style=\"font-variation-settings: 'FILL' 1;\">description</span>\n</div>\n<h3 class=\"font-headline text-xl font-bold text-on-surface\">Documents</h3>\n</div>\n<span class=\"font-label text-xs font-semibold text-tertiary-container bg-tertiary-container/10 px-3 py-1 rounded-full\">2/5 Items</span>\n</div>\n<div class=\"flex flex-col gap-1\">\n<div class=\"group flex items-center justify-between p-3 rounded-xl hover:bg-surface-container-low transition-all duration-300\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-6 h-6 rounded-md border-2 border-tertiary-container flex items-center justify-center cursor-pointer bg-tertiary-container\" style=\"font-variation-settings: 'FILL' 1;\">\n<span class=\"material-symbols-outlined text-white text-sm\">check</span>\n</div>\n<span class=\"text-on-surface-variant line-through opacity-60\">Digital Boarding Pass</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant opacity-0 group-hover:opacity-100 hover:text-error transition-all cursor-pointer text-xl\">delete</span>\n</div>\n<div class=\"group flex items-center justify-between p-3 rounded-xl hover:bg-surface-container-low transition-all duration-300\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-6 h-6 rounded-md border-2 border-outline-variant flex items-center justify-center cursor-pointer hover:border-tertiary-container transition-colors\"></div>\n<span class=\"text-on-surface\">Travel Insurance Policy PDF</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant opacity-0 group-hover:opacity-100 hover:text-error transition-all cursor-pointer text-xl\">delete</span>\n</div>\n<div class=\"group flex items-center justify-between p-3 rounded-xl hover:bg-surface-container-low transition-all duration-300\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-6 h-6 rounded-md border-2 border-outline-variant flex items-center justify-center cursor-pointer hover:border-tertiary-container transition-colors\"></div>\n<span class=\"text-on-surface\">Offline Maps Downloaded</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant opacity-0 group-hover:opacity-100 hover:text-error transition-all cursor-pointer text-xl\">delete</span>\n</div>\n</div>\n<div class=\"mt-4 pt-6 border-t border-surface-container\">\n<div class=\"relative group\">\n<input class=\"w-full bg-surface-container-highest border-none rounded-md px-4 py-3 text-sm focus:ring-2 focus:ring-tertiary-container/20 transition-all placeholder:text-outline-variant\" placeholder=\"Add New Document...\" type=\"text\"/>\n<button class=\"absolute right-2 top-1.5 p-1.5 bg-tertiary-container text-white rounded-md opacity-0 group-focus-within:opacity-100 transition-opacity\">\n<span class=\"material-symbols-outlined text-sm\">add</span>\n</button>\n</div>\n</div>\n</section>\n<!-- Section: Essentials (Bento Style) -->\n<div class=\"md:col-span-2 grid grid-cols-1 md:grid-cols-3 gap-8\">\n<section class=\"md:col-span-2 bg-surface-container-lowest rounded-lg aura-shadow p-8 flex flex-col gap-6 overflow-hidden relative\">\n<div class=\"absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-bl-full -mr-8 -mt-8\"></div>\n<div class=\"flex items-center gap-3\">\n<div class=\"p-2 bg-secondary-container/20 rounded-full\">\n<span class=\"material-symbols-outlined text-secondary\" style=\"font-variation-settings: 'FILL' 1;\">luggage</span>\n</div>\n<h3 class=\"font-headline text-xl font-bold text-on-surface\">Daily Essentials</h3>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-2\">\n<div class=\"flex items-center gap-3 p-3 bg-surface-container-low rounded-xl border border-white/50\">\n<div class=\"w-5 h-5 rounded border border-outline-variant\"></div>\n<span class=\"text-sm font-medium\">Noise Cancelling Headphones</span>\n</div>\n<div class=\"flex items-center gap-3 p-3 bg-surface-container-low rounded-xl border border-white/50\">\n<div class=\"w-5 h-5 rounded border border-outline-variant\"></div>\n<span class=\"text-sm font-medium\">Power Bank (20,000mAh)</span>\n</div>\n<div class=\"flex items-center gap-3 p-3 bg-primary-container/10 rounded-xl border border-primary-container/20\">\n<span class=\"material-symbols-outlined text-primary text-lg\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>\n<span class=\"text-sm font-medium text-on-primary-container\">Universal Travel Adapter</span>\n</div>\n<div class=\"flex items-center gap-3 p-3 bg-surface-container-low rounded-xl border border-white/50\">\n<div class=\"w-5 h-5 rounded border border-outline-variant\"></div>\n<span class=\"text-sm font-medium\">Reusable Water Bottle</span>\n</div>\n</div>\n</section>\n<div class=\"bg-primary p-8 rounded-lg flex flex-col justify-between text-white relative overflow-hidden\">\n<div class=\"absolute bottom-0 right-0 opacity-10\">\n<span class=\"material-symbols-outlined text-[120px]\">task_alt</span>\n</div>\n<div>\n<h4 class=\"font-headline text-2xl font-bold mb-2\">Almost Ready</h4>\n<p class=\"text-primary-fixed text-sm\">You have completed 65% of your total trip preparation.</p>\n</div>\n<button class=\"bg-white text-primary px-6 py-3 rounded-full font-label text-sm font-bold mt-6 self-start hover:bg-primary-fixed transition-colors\">\n                    View Progress\n                </button>\n</div>\n</div>\n</div>\n</main>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 dark:bg-slate-950/80 backdrop-blur-lg rounded-t-[2.5rem] shadow-[0_-10px_40px_-12px_rgba(0,0,0,0.1)] md:hidden\">\n<a class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 px-5 py-2 hover:text-sky-400 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">home</span>\n<span class=\"font-['Inter'] text-[10px] font-semibold uppercase tracking-widest mt-1\">Home</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-sky-500 dark:text-sky-400 bg-sky-50 dark:bg-sky-900/20 rounded-full px-5 py-2 translate-y-[-2px] transition-transform\" href=\"#\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">explore</span>\n<span class=\"font-['Inter'] text-[10px] font-semibold uppercase tracking-widest mt-1\">Trips</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 px-5 py-2 hover:text-sky-400 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">edit_note</span>\n<span class=\"font-['Inter'] text-[10px] font-semibold uppercase tracking-widest mt-1\">Journal</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 px-5 py-2 hover:text-sky-400 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">settings</span>\n<span class=\"font-['Inter'] text-[10px] font-semibold uppercase tracking-widest mt-1\">Settings</span>\n</a>\n</nav>\n<script>\n    function toggleDrawer() {\n        const drawer = document.getElementById('nav-drawer');\n        const overlay = document.getElementById('nav-overlay');\n        drawer.classList.toggle('open');\n        overlay.classList.toggle('open');\n        \n        // Prevent background scrolling when drawer is open\n        if (drawer.classList.contains('open')) {\n            document.body.style.overflow = 'hidden';\n        } else {\n            document.body.style.overflow = '';\n        }\n    }\n</script>\n</body></html>"}
