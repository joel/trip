{"screenId":"e08cb33d51414c61984211425aa6e320","projectId":"3314239195447065678","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Catalyst | Collaboration Hub</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"tertiary\": \"#855300\",\n              \"inverse-on-surface\": \"#eef0ff\",\n              \"surface-container-low\": \"#f2f3ff\",\n              \"surface\": \"#faf8ff\",\n              \"secondary-fixed-dim\": \"#45dfa4\",\n              \"on-primary-container\": \"#004965\",\n              \"on-tertiary-fixed\": \"#2a1700\",\n              \"on-error\": \"#ffffff\",\n              \"primary-fixed\": \"#c4e7ff\",\n              \"outline\": \"#6e7980\",\n              \"secondary\": \"#006c4b\",\n              \"inverse-primary\": \"#7bd0ff\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"surface-container-high\": \"#e2e7ff\",\n              \"primary\": \"#00668a\",\n              \"surface-container\": \"#eaedff\",\n              \"background\": \"#faf8ff\",\n              \"surface-dim\": \"#d2d9f4\",\n              \"on-surface-variant\": \"#3e484f\",\n              \"secondary-fixed\": \"#68fcbf\",\n              \"on-secondary-fixed-variant\": \"#005137\",\n              \"inverse-surface\": \"#283044\",\n              \"error-container\": \"#ffdad6\",\n              \"on-primary-fixed-variant\": \"#004c69\",\n              \"primary-container\": \"#38bdf8\",\n              \"on-surface\": \"#131b2e\",\n              \"outline-variant\": \"#bdc8d1\",\n              \"on-tertiary\": \"#ffffff\",\n              \"surface-container-highest\": \"#dae2fd\",\n              \"on-background\": \"#131b2e\",\n              \"secondary-container\": \"#64f9bc\",\n              \"on-secondary-fixed\": \"#002114\",\n              \"on-secondary-container\": \"#00714e\",\n              \"surface-variant\": \"#dae2fd\",\n              \"tertiary-fixed\": \"#ffddb8\",\n              \"on-secondary\": \"#ffffff\",\n              \"tertiary-container\": \"#f1a02b\",\n              \"on-primary\": \"#ffffff\",\n              \"tertiary-fixed-dim\": \"#ffb960\",\n              \"surface-bright\": \"#faf8ff\",\n              \"on-tertiary-fixed-variant\": \"#653e00\",\n              \"error\": \"#ba1a1a\",\n              \"surface-tint\": \"#00668a\",\n              \"on-error-container\": \"#93000a\",\n              \"primary-fixed-dim\": \"#7bd0ff\",\n              \"on-primary-fixed\": \"#001e2c\",\n              \"on-tertiary-container\": \"#613b00\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Inter\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"1rem\", \"lg\": \"1.5rem\", \"xl\": \"3rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.6);\n            backdrop-filter: blur(20px) saturate(180%);\n            border: 1px solid rgba(255, 255, 255, 0.4);\n        }\n        .aura-shadow {\n            box-shadow: 0 12px 30px -10px rgba(19, 27, 46, 0.06);\n        }\n        .primary-gradient {\n            background: linear-gradient(135deg, #00668a, #38bdf8);\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .blob-bg {\n            position: fixed;\n            z-index: -1;\n            filter: blur(80px);\n            opacity: 0.4;\n            pointer-events: none;\n        }\n    </style>\n</head>\n<body class=\"bg-background font-body text-on-surface min-h-screen\">\n<!-- Background Blobs -->\n<div class=\"blob-bg bg-sky-200 w-64 h-64 top-20 right-0 rounded-full\"></div>\n<div class=\"blob-bg bg-indigo-100 w-96 h-96 bottom-0 left-0 rounded-full\"></div>\n<!-- TopAppBar -->\n<header class=\"fixed top-0 w-full z-40 bg-white/70 dark:bg-[#faf8ff]/10 backdrop-blur-xl flex justify-between items-center px-6 h-16\">\n<div class=\"flex items-center gap-4\">\n<button class=\"text-sky-500 hover:opacity-80 transition-opacity active:scale-95 duration-200\">\n<span class=\"material-symbols-outlined\" data-icon=\"menu\">menu</span>\n</button>\n<h1 class=\"font-['Space_Grotesk'] font-semibold text-lg text-slate-900 dark:text-white\">Trip Journal</h1>\n</div>\n<div class=\"h-8 w-8 rounded-full overflow-hidden border border-sky-200\">\n<img alt=\"User profile\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBepFhNa7YrqoayZ6Cu3wdL2s6CMnsXFa8kBM1K-fBg7CoEbcJjg5sodC9-SRQIDY2XfkmCqQYW2nBDyr3Ue5scMNjMsdvzhaOEZmgcBpiatRYvg55pPsnGMJ5q1OWnIocIWHSbjs0-YyUin2Pc78TgvzXkSbMDS-tQOdZmhCL1D64mabVK3QCGZGwIkYotwKuvGZOGUs_F2dzcx3YlCBf64yWIquQdaR2sSEkNj_pJx7iMBYMO-mwrBbaNNCT2_SkbmSVdxuppSqw\"/>\n</div>\n</header>\n<!-- NavigationDrawer (Desktop) -->\n<aside class=\"hidden lg:flex flex-col fixed inset-y-0 left-0 z-50 w-72 bg-[#0b1220] rounded-r-[2rem] shadow-[0_20px_40px_-12px_rgba(11,18,32,0.5)] font-['Space_Grotesk'] antialiased tracking-tight\">\n<div class=\"p-8\">\n<div class=\"flex items-center gap-4 mb-10\">\n<div class=\"w-12 h-12 rounded-full border-2 border-sky-400 p-0.5\">\n<img alt=\"User Profile\" class=\"w-full h-full rounded-full object-cover\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBepFhNa7YrqoayZ6Cu3wdL2s6CMnsXFa8kBM1K-fBg7CoEbcJjg5sodC9-SRQIDY2XfkmCqQYW2nBDyr3Ue5scMNjMsdvzhaOEZmgcBpiatRYvg55pPsnGMJ5q1OWnIocIWHSbjs0-YyUin2Pc78TgvzXkSbMDS-tQOdZmhCL1D64mabVK3QCGZGwIkYotwKuvGZOGUs_F2dzcx3YlCBf64yWIquQdaR2sSEkNj_pJx7iMBYMO-mwrBbaNNCT2_SkbmSVdxuppSqw\"/>\n</div>\n<div>\n<h3 class=\"font-bold text-white text-lg\">Alex Rivers</h3>\n<p class=\"text-sky-400 text-xs\">Global Explorer</p>\n</div>\n</div>\n<nav class=\"space-y-2\">\n<a class=\"text-slate-400 hover:text-white hover:bg-white/5 rounded-2xl px-4 py-3 flex items-center gap-3 transition-all duration-300\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"edit_note\">edit_note</span> Journal\n                </a>\n<a class=\"text-slate-400 hover:text-white hover:bg-white/5 rounded-2xl px-4 py-3 flex items-center gap-3 transition-all duration-300\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"map\">map</span> Map\n                </a>\n<a class=\"text-slate-400 hover:text-white hover:bg-white/5 rounded-2xl px-4 py-3 flex items-center gap-3 transition-all duration-300\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"photo_library\">photo_library</span> Memories\n                </a>\n<a class=\"bg-sky-500/10 text-sky-400 rounded-2xl px-4 py-3 flex items-center gap-3 transition-all duration-300\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"explore\">explore</span> Discover\n                </a>\n<a class=\"text-slate-400 hover:text-white hover:bg-white/5 rounded-2xl px-4 py-3 flex items-center gap-3 transition-all duration-300\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"settings\">settings</span> Settings\n                </a>\n</nav>\n</div>\n</aside>\n<main class=\"pt-24 pb-32 px-6 lg:ml-72 max-w-4xl mx-auto\">\n<!-- Header Section -->\n<div class=\"mb-10 space-y-2\">\n<h2 class=\"text-4xl font-headline font-bold text-on-surface tracking-tight\">Collaboration Hub</h2>\n<p class=\"text-on-surface-variant text-sm max-w-lg\">Manage team roles and review workspace access requests.</p>\n</div>\n<!-- Vertical Stack of Sections -->\n<div class=\"space-y-12\">\n<!-- Active Team Section -->\n<section class=\"space-y-4\">\n<div class=\"flex items-center justify-between\">\n<h3 class=\"font-headline text-xl font-bold flex items-center gap-3\">\n                        Active Team\n                        <span class=\"text-[10px] bg-sky-100 text-sky-700 px-2 py-0.5 rounded-full font-bold\">12</span>\n</h3>\n<button class=\"text-primary text-sm font-semibold hover:opacity-70 transition-opacity\">Invite New</button>\n</div>\n<div class=\"space-y-3\">\n<!-- Member Card 1 -->\n<div class=\"bg-white p-4 rounded-lg aura-shadow border border-white/50 flex items-center gap-4 group transition-all hover:scale-[1.01]\">\n<img alt=\"Sarah Chen\" class=\"w-12 h-12 rounded-full object-cover ring-2 ring-sky-50\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuC1zzpvf3YCTK25PDY8uMbC8IA4k0I86mmUVGLa24xJzOTMVizbFAiqOjOZhg8guTtFEeG5nFFWgBvRR3HNnsdu1XZkyW02O_KtJkAyZInKm9CwcJ9KgL08I71K9VictJJY9Ib2YtFSd4MGyMZf36ToI8pvACkaaYEZdkZoUvEr_coGpfOo08xf7rexGkU7RgA-uM0qZDnePf_WWt-n3eI8cwqMW4AaSqaddOTP1SnqyiZ_rZtPBdC4kpIwjVDia9sYPGSJYJNhiA4\"/>\n<div class=\"flex-grow\">\n<h4 class=\"font-bold text-on-surface text-sm\">Sarah Chen</h4>\n<p class=\"text-xs text-on-surface-variant\">Editor</p>\n</div>\n<button class=\"p-2 hover:bg-surface-container rounded-full text-outline transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n<!-- Member Card 2 -->\n<div class=\"bg-white p-4 rounded-lg aura-shadow border border-white/50 flex items-center gap-4 group transition-all hover:scale-[1.01]\">\n<img alt=\"Marcus Wright\" class=\"w-12 h-12 rounded-full object-cover ring-2 ring-sky-50\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDVSMI7UV8UZnKw8RAxegzB59-zTspCmDem0uzsb-96FNw9648wZBtXvr3-5NCPykRUtYE_3rEMOA7l4BEHyciwkxo9i_wCVEEPM28w18Ugv0dCoUAEYnc9oeAD3D6T-H0R7rlmmJ9uOEb9mI2lFyA1XziIngvrapYcZHzw5qKCTASLxzRFkQe6apiyCsKhL1qOtZEDS9Bb3VSnnp9Nm_NaZhvqMudC7hT-FsIacc5TBgWQ3qeRB346Pm3O1A5oaVTxW6nl77MQJMU\"/>\n<div class=\"flex-grow\">\n<h4 class=\"font-bold text-on-surface text-sm\">Marcus Wright</h4>\n<p class=\"text-xs text-on-surface-variant\">Editor</p>\n</div>\n<button class=\"p-2 hover:bg-surface-container rounded-full text-outline transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n<!-- Member Card 3 -->\n<div class=\"bg-white p-4 rounded-lg aura-shadow border border-white/50 flex items-center gap-4 group transition-all hover:scale-[1.01]\">\n<div class=\"w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 font-bold text-sm\">JW</div>\n<div class=\"flex-grow\">\n<h4 class=\"font-bold text-on-surface text-sm\">James Wu</h4>\n<p class=\"text-xs text-on-surface-variant\">Viewer</p>\n</div>\n<button class=\"p-2 hover:bg-surface-container rounded-full text-outline transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n</div>\n</section>\n<!-- Pending Invitations Section -->\n<section class=\"space-y-4\">\n<h3 class=\"font-headline text-xl font-bold\">Pending Invitations</h3>\n<div class=\"bg-white/40 rounded-lg p-2 aura-shadow\">\n<!-- Invite List Item 1 -->\n<div class=\"flex items-center justify-between p-4 border-b border-white/50 last:border-0\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-slate-400 scale-75\" data-icon=\"alternate_email\">alternate_email</span>\n<div>\n<p class=\"text-sm font-medium\">david.vance@studio.com</p>\n<p class=\"text-[10px] text-outline uppercase tracking-wider font-bold\">Editor • Sent 2d ago</p>\n</div>\n</div>\n<button class=\"text-[10px] font-bold text-error border border-error/20 px-3 py-1.5 rounded-full hover:bg-error/5 transition-colors uppercase tracking-widest\">Cancel</button>\n</div>\n<!-- Invite List Item 2 -->\n<div class=\"flex items-center justify-between p-4 last:border-0\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-slate-400 scale-75\" data-icon=\"alternate_email\">alternate_email</span>\n<div>\n<p class=\"text-sm font-medium\">tina.f@creative-hub.net</p>\n<p class=\"text-[10px] text-outline uppercase tracking-wider font-bold\">Viewer • Sent 5h ago</p>\n</div>\n</div>\n<button class=\"text-[10px] font-bold text-error border border-error/20 px-3 py-1.5 rounded-full hover:bg-error/5 transition-colors uppercase tracking-widest\">Cancel</button>\n</div>\n</div>\n</section>\n<!-- Access Requests Section -->\n<section class=\"space-y-4\">\n<div class=\"flex items-center gap-3\">\n<h3 class=\"font-headline text-xl font-bold\">Access Requests</h3>\n<span class=\"text-[10px] bg-error-container text-error px-2 py-0.5 rounded-full font-bold uppercase tracking-wider\">New</span>\n</div>\n<div class=\"space-y-4\">\n<!-- Glassy Request Card -->\n<div class=\"glass-panel p-6 rounded-lg aura-shadow border-t border-l border-white/60\">\n<div class=\"flex items-start gap-4 mb-5\">\n<div class=\"w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-xs\">LO</div>\n<div class=\"space-y-1\">\n<h4 class=\"font-bold text-on-surface text-sm\">Liam O'Conner</h4>\n<p class=\"text-xs text-on-surface-variant\">Requesting <span class=\"font-semibold text-primary\">Editor</span> access</p>\n<p class=\"text-xs text-outline italic bg-surface-container/50 p-2 rounded-lg mt-2\">\"Need access to update the July roadmap.\"</p>\n</div>\n</div>\n<div class=\"flex gap-3\">\n<button class=\"flex-1 bg-emerald-600 text-white text-[11px] font-bold py-2.5 rounded-full hover:bg-emerald-700 transition-colors uppercase tracking-widest\">Approve</button>\n<button class=\"flex-1 bg-rose-500 text-white text-[11px] font-bold py-2.5 rounded-full hover:bg-rose-600 transition-colors uppercase tracking-widest\">Reject</button>\n</div>\n</div>\n<!-- Empty State Placeholder (Example) -->\n<!-- \n                    <div class=\"flex flex-col items-center justify-center py-12 px-6 border-2 border-dashed border-slate-200 rounded-lg text-slate-400\">\n                        <span class=\"material-symbols-outlined text-4xl mb-2\" data-icon=\"notifications_off\">notifications_off</span>\n                        <p class=\"text-sm font-medium\">No pending requests at the moment</p>\n                    </div>\n                    -->\n</div>\n</section>\n</div>\n</main>\n<!-- BottomNavBar (Mobile) -->\n<nav class=\"md:hidden fixed bottom-0 left-0 w-full z-50 bg-white/80 dark:bg-white/10 backdrop-blur-2xl border-t border-white/20 shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.1)] rounded-t-[2.5rem] flex justify-around items-center px-4 pb-6 pt-3\">\n<button class=\"flex flex-col items-center justify-center text-slate-400 hover:text-sky-400 transition-all active:translate-y-[-2px] duration-300\">\n<span class=\"material-symbols-outlined\" data-icon=\"home\">home</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest mt-1\">Home</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-slate-400 hover:text-sky-400 transition-all active:translate-y-[-2px] duration-300\">\n<span class=\"material-symbols-outlined\" data-icon=\"draw\">draw</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest mt-1\">Drafts</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-slate-400 hover:text-sky-400 transition-all active:translate-y-[-2px] duration-300\">\n<span class=\"material-symbols-outlined\" data-icon=\"bookmark\">bookmark</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest mt-1\">Saved</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-sky-500 font-bold scale-110 transition-all active:translate-y-[-2px] duration-300\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-bold uppercase tracking-widest mt-1\">Profile</span>\n</button>\n</nav>\n</body></html>"}
