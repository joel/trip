15) 0%, transparent 40%),\n                        radial-gradient(circle at 80% 70%, rgba(100, 249, 188, 0.1) 0%, transparent 40%);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-surface antialiased min-h-screen\">\n<!-- NavigationDrawer (Predicted Shared Component) -->\n<aside class=\"fixed inset-y-0 left-0 z-50 flex flex-col bg-[#0b1220] dark:bg-[#0b1220] rounded-r-[2rem] h-full w-72 shadow-[0_20px_40px_-12px_rgba(11,18,32,0.5)] font-['Space_Grotesk'] antialiased tracking-tight hidden md:flex\">\n<div class=\"p-8 flex flex-col h-full\">\n<div class=\"mb-12 flex items-center gap-4\">\n<img alt=\"User Profile\" class=\"w-12 h-12 rounded-2xl object-cover\" data-alt=\"professional portrait of a young traveler with a friendly expression, soft cinematic lighting, outdoor urban background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuANNQyXtGzmQ5vwXfajnCNYt2Jyl67_sqdU4i0Qxf2q8Kk7LIZtLr3SkKM9Fe1rV_ZDYFBKfruvOXkyJyN9YAzek2BHVaOIigoZCILeXvLrwgV309ZltKdYtUDRpN5Bcx9XT3sfBeNDy-8c6WONUAvU1xRS2OVgDKFXWI2NpmA3hR8CjA24DiRcX5fkb-yqKs3NbRBhFj_odsbbtN1dPw60n845h0WGoPo90rZwACy8LC_ZxC2S0DMc_r4gWiQNsXI-OagGBc82-FQ\"/>\n<div>\n<h3 class=\"text-white font-bold text-lg leading-tight\">Alex Rivers</h3>\n<p class=\"text-sky-400 text-sm\">Global Explorer</p>\n<p class=\"text-slate-500 text-[10px] mt-1 uppercase tracking-widest\">128 Entries</p>\n</div>\n</div>\n<nav class=\"flex-1 space-y-2\">\n<a class=\"bg-sky-500/10 text-sky-400 rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300\" href=\"#\">\n<span class=\"material-symbols-outlined\">edit_note</span>\n<span class=\"font-medium\">Journal</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\">map</span>\n<span class=\"font-medium\">Map</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\">photo_library</span>\n<span class=\"font-medium\">Memories</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\">explore</span>\n<span class=\"font-medium\">Discover</span>\n</a>\n</nav>\n<div class=\"mt-auto\">\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\">settings</span>\n<span class=\"font-medium\">Settings</span>\n</a>\n</div>\n</div>\n</aside>\n<!-- Main Content Canvas -->\n<main class=\"md:pl-72 min-h-screen bg-aura relative overflow-hidden\">\n<!-- Header: TopAppBar (Modified for Detail View) -->\n<header class=\"sticky top-0 w-full z-40 bg-white/70 backdrop-blur-xl flex justify-between items-center px-6 h-16\">\n<div class=\"flex items-center gap-4\">\n<button class=\"p-2 text-on-surface-variant hover:bg-surface-container rounded-full transition-colors flex items-center justify-center\">\n<span class=\"material-symbols-outlined\">arrow_back</span>\n</button>\n<div>\n<h1 class=\"font-headline font-bold text-lg text-slate-900 leading-tight\">Sunrise at Seceda</h1>\n<p class=\"font-body text-[11px] text-on-surface-variant uppercase tracking-widest font-medium\">October 14, 2023 • Dolomites, Italy</p>\n</div>\n</div>\n<div class=\"flex items-center gap-3\">\n<button class=\"p-2 text-on-surface-variant hover:bg-surface-container rounded-full transition-colors\">\n<span class=\"material-symbols-outlined\">share</span>\n</button>\n<button class=\"p-2 text-on-surface-variant hover:bg-surface-container rounded-full transition-colors\">\n<span class=\"material-symbols-outlined\">more_vert</span>\n</button>\n</div>\n</header>\n<!-- Journal Content Area -->\n<div class=\"max-w-4xl mx-auto px-6 py-12 pb-32\">\n<!-- Hero Image / Gallery Section -->\n<section class=\"mb-12 relative\">\n<div class=\"grid grid-cols-12 gap-4 h-[500px]\">\n<div class=\"col-span-8 h-full rounded-lg overflow-hidden group\">\n<img class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" data-alt=\"dramatic sunrise over the sharp mountain peaks of Seceda in the Dolomites, golden light hitting the jagged edges with soft mist in the valley\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuATDVrYor-lsa3NqKpuz3O3Dx8T44xU4zJJrJNTkpLBPIrZ48u_VLNp4QjohWDP6nHSIW_t-ZPsxY3rrkeL3rJYLd7tOnKaXhnVk8QkRYiizO_tlUOcxYOF7jrAy0a8dIFm115BxXPi5cnWS1ax47AfdfxhFtPfZ4Z5UcskOPPMzgAUaQo3eRLWiBTNzgYxMKMjGZHjGWKXyFwvSkapIlJS19_B7dQX4m3DPWnrE0rk7cbHM1AWlN4SxZlxdAP3WRKY4B-4goL8etE\"/>\n</div>\n<div class=\"col-span-4 flex flex-col gap-4 h-full\">\n<div class=\"h-1/2 rounded-lg overflow-hidden\">\n<img class=\"w-full h-full object-cover\" data-alt=\"close up of alpine wildflowers with blurred mountain background in the morning dew, soft pastel colors\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuD3kIMOaFWNYBN6ol8TDFcyFgOnBYWOmG1xN_nPSPP_JxiqVQ_6doPtHikQ6y25iEwTpJsJbXgEJbeDLqrPowgcsw9OvD_ha62E73m1lWuuj1rAtq12g8tdHIxz3slNDrFhUAFvVKuRUXSaN4OIyh_2yrdNEN96SM0ykdDsVo0t4eFR91EmF-UiIL-ck-PX7AqkfnY9g5ldjneZJ0-lU1Bm4Z_PGoqXO80p_1dSyNMehTz9jucpFwrmfWMkOrHZ_mbqVzY2_utozGo\"/>\n</div>\n<div class=\"h-1/2 rounded-lg overflow-hidden relative\">\n<img class=\"w-full h-full object-cover\" data-alt=\"wide shot of the majestic mountain range under a clear blue sky, high altitude landscape photography\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBPYgVVE1qP9ZC1Hx9rzmi9v3UrjPu1bORDTPRCnqmtFBZLVkLy6jMdrn14YGfIGese8cbfgWTylc604x8OxRPuz7ZXohIFr9nHc9A4eBSXjUTvjzoDK31Lr9zXVHpjmQdOsx4nThFPjI414kRxZRBNpsX8sk-7jxONT2VFIeOYpXGuMTp27oQYRiajSMJ1d5ZkKEkfpmp8BNHi4eEWL3sPH7fsaeecdxBKAOlsH7oq_oHiFIRUpW9slTQ0aQJSNhElc1k3OUEe55M\"/>\n<div class=\"absolute inset-0 bg-black/40 backdrop-blur-[2px] flex items-center justify-center cursor-pointer hover:bg-black/30 transition-colors\">\n<span class=\"text-white font-headline font-bold text-2xl\">+12</span>\n</div>\n</div>\n</div>\n</div>\n<!-- ReactionSummary Component -->\n<div class=\"absolute -bottom-6 left-1/2 -translate-x-1/2 bg-white/80 backdrop-blur-2xl px-6 py-3 rounded-full shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] flex items-center gap-6 border border-white/40\">\n<button class=\"flex items-center gap-2 hover:scale-110 transition-transform\">\n<span class=\"text-xl\">❤️</span>\n<span class=\"font-headline font-bold text-sm text-on-surface\">42</span>\n</button>\n<div class=\"w-px h-4 bg-outline-variant/30\"></div>\n<button class=\"flex items-center gap-2 hover:scale-110 transition-transform\">\n<span class=\"text-xl\">😍</span>\n<span class=\"font-headline font-bold text-sm text-on-surface\">18</span>\n</button>\n<div class=\"w-px h-4 bg-outline-variant/30\"></div>\n<button class=\"flex items-center gap-2 hover:scale-110 transition-transform\">\n<span class=\"text-xl\">📸</span>\n<span class=\"font-headline font-bold text-sm text-on-surface\">7</span>\n</button>\n</div>\n</section>\n<!-- Text Content -->\n<article class=\"prose prose-slate max-w-none\">\n<h2 class=\"font-headline text-4xl font-bold text-slate-900 mb-8 tracking-tight\">The air at 2,500 meters tastes different.</h2>\n<div class=\"font-body text-lg text-on-surface-variant leading-relaxed space-y-6\">\n<p>\n                        We started the ascent at 4:30 AM. The world was still a silent, monochromatic shadow as our headlamps cut through the crisp mountain air. Every breath felt like a renewal, a sharp reminder of the altitude and the raw power of the Dolomites.\n                    </p>\n<p>\n                        As we reached the ridgeline of Seceda, the first hints of amber began to bleed through the deep indigo of the horizon. It wasn't a sudden burst, but a slow, intentional unveiling. The jagged peaks, famous for their razor-sharp silhouettes, began to catch the light—turning from grey to purple, then finally to a burning, brilliant orange.\n                    </p>\n<blockquote class=\"border-l-4 border-primary pl-6 my-12 italic font-headline text-2xl text-slate-800 font-medium\">\n                        \"Nature is not a place to visit. It is home.\" — The realization hit differently as the sun finally cleared the peaks.\n                    </blockquote>\n<p>\n                        I spent hours just sitting there, watching the shadows retract across the valley floor. There's a profound stillness that comes with being above the clouds. You realize that while the world below is waking up to noise and schedules, up here, the only clock is the movement of light.\n                    </p>\n</div>\n</article>\n<!-- Comments Section -->\n<section class=\"mt-20 pt-12 border-t border-surface-container-high\">\n<div class=\"flex items-center justify-between mb-10\">\n<h3 class=\"font-headline text-2xl font-bold text-slate-900\">Conversations <span class=\"text-on-surface-variant font-normal text-lg ml-2\">(3)</span></h3>\n<div class=\"flex items-center gap-2 text-sm text-primary font-medium cursor-pointer\">\n<span>Newest First</span>\n<span class=\"material-symbols-outlined text-sm\">expand_more</span>\n</div>\n</div>\n<!-- Comment Cards -->\n<div class=\"space-y-6 mb-12\">\n<!-- Comment 1 -->\n<div class=\"bg-surface-container-lowest p-6 rounded-lg shadow-[0_4px_20px_-4px_rgba(19,27,46,0.05)] border border-outline-variant/10\">\n<div class=\"flex gap-4\">\n<img alt=\"Author\" class=\"w-10 h-10 rounded-full object-cover\" data-alt=\"close-up portrait of a man with sunglasses and hiking gear, smiling, outdoors in bright daylight\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuC14RGGhLOO6Aks3tm3RKbfenPcUBi1347sIL9tGP_wlTtYhq6nH2K95B8EC9iuaD-YrefcEcadRLRI_pGNhGXBrc2VQloZ5MxpTj-2yvUrd3EZs7hzAbwMxvG8ptTqCuj4cOgej-55PZL8xQGDs7zwJexM4s0JToFXK0NtCRla47czLNuk_IVEEd0utNa72bxRitrx7vFypHOGMedo_FA4A8ivSzJCOpgdOiiS-30iNuwDezznoWs6H9jaN0ZgN-XKF_drL3gxEwQ\"/>\n<div class=\"flex-1\">\n<div class=\"flex justify-between items-start\">\n<h4 class=\"font-headline font-bold text-slate-900\">Marcus Thorne</h4>\n<span class=\"text-[11px] text-on-surface-variant uppercase tracking-widest font-bold\">2 Hours ago</span>\n</div>\n<p class=\"font-body text-on-surface-variant mt-2\">These shots are breathtaking. I was there last July but the weather didn't cooperate. This golden hour light is everything!</p>\n<div class=\"mt-4 flex items-center gap-4 text-sm font-medium text-on-surface-variant\">\n<button class=\"flex items-center gap-1 hover:text-primary transition-colors\">\n<span class=\"material-symbols-outlined text-lg\">thumb_up</span> 12\n                                    </button>\n<button class=\"flex items-center gap-1 hover:text-primary transition-colors\">\n<span class=\"material-symbols-outlined text-lg\">reply</span> Reply\n                                    </button>\n</div>\n</div>\n</div>\n</div>\n<!-- Comment 2 -->\n<div class=\"bg-surface-container-lowest p-6 rounded-lg shadow-[0_4px_20px_-4px_rgba(19,27,46,0.05)] border border-outline-variant/10 ml-12\">\n<div class=\"flex gap-4\">\n<img alt=\"Author\" class=\"w-10 h-10 rounded-full object-cover\" data-alt=\"portrait of a woman with a camera around her neck, artistic lighting, creative studio background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAwLj32eJwfxpS3XrLD_JInR9PBMP__xFVqsi0ePg-1HVNUsTaGEWG1ldKCt1jFpQXO3r8Yh0Ih478Ljj2emlzHdiQzKi2Fk2vIryKgX7kBNL05-NYNjJ6wTosv4q7WyRPrecnD9EUDKB4cBgWKMSGsflHgJybIDRQ_HnBkf0dDS6bTUaQ8I86BjV3ofJ0KAZt9nHHK0en6td5CL8UvG4VJYGdb-7tKzQDoyRVuPbmYyyZO9wCG-PbpE6U3SeiY2-7Koh2Nw2roVjU\"/>\n<div class=\"flex-1\">\n<div class=\"flex justify-between items-start\">\n<h4 class=\"font-headline font-bold text-slate-900\">Sarah Chen</h4>\n<span class=\"text-[11px] text-on-surface-variant uppercase tracking-widest font-bold\">45 Mins ago</span>\n</div>\n<p class=\"font-body text-on-surface-variant mt-2\">Agreed @Marcus! Which lens did you use for that wide shot? The sharpness is incredible.</p>\n<div class=\"mt-4 flex items-center gap-4 text-sm font-medium text-on-surface-variant\">\n<button class=\"flex items-center gap-1 hover:text-primary transition-colors\">\n<span class=\"material-symbols-outlined text-lg\">thumb_up</span> 3\n                                    </button>\n<button class=\"flex items-center gap-1 hover:text-primary transition-colors\">\n<span class=\"material-symbols-outlined text-lg\">reply</span> Reply\n                                    </button>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!-- Rich Text Input -->\n<div class=\"bg-surface-container-low p-4 rounded-lg flex flex-col gap-4\">\n<div class=\"flex items-center gap-3 px-2 border-b border-outline-variant/20 pb-2\">\n<button class=\"p-1.5 text-on-surface-variant hover:bg-surface-container-highest rounded-md transition-colors\"><span class=\"material-symbols-outlined text-xl\">format_bold</span></button>\n<button class=\"p-1.5 text-on-surface-variant hover:bg-surface-container-highest rounded-md transition-colors\"><span class=\"material-symbols-outlined text-xl\">format_italic</span></button>\n<button class=\"p-1.5 text-on-surface-variant hover:bg-surface-container-highest rounded-md transition-colors\"><span class=\"material-symbols-outlined text-xl\">link</span></button>\n<div class=\"w-px h-4 bg-outline-variant/30\"></div>\n<button class=\"p-1.5 text-on-surface-variant hover:bg-surface-container-highest rounded-md transition-colors\"><span class=\"material-symbols-outlined text-xl\">image</span></button>\n</div>\n<textarea class=\"w-full bg-transparent border-none focus:ring-0 text-on-surface placeholder:text-slate-400 font-body min-h-[100px] resize-none\" placeholder=\"Write your thoughts...\"></textarea>\n<div class=\"flex justify-end\">\n<button class=\"bg-gradient-to-br from-primary to-primary-container text-white font-headline font-bold px-8 py-3 rounded-full shadow-lg shadow-primary/20 hover:translate-y-[-2px] transition-all duration-300\">\n                            Post Comment\n                        </button>\n</div>\n</div>\n</section>\n</div>\n<!-- Floating Action Button (FAB) - Suppressed per rules on Detail Screens -->\n<!-- BottomNavBar (Predicted Shared Component for Mobile) -->\n<nav class=\"md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 backdrop-blur-2xl border-t border-white/20 shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.1)] rounded-t-[2.5rem] font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest\">\n<a class=\"flex flex-col items-center justify-center text-slate-400\" href=\"#\">\n<span class=\"material-symbols-outlined\">home</span>\n<span class=\"mt-1\">Home</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-sky-500 font-bold scale-110\" href=\"#\">\n<span class=\"material-symbols-outlined\">draw</span>\n<span class=\"mt-1\">Journal</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-slate-400\" href=\"#\">\n<span class=\"material-symbols-outlined\">bookmark</span>\n<span class=\"mt-1\">Saved</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-slate-400\" href=\"#\">\n<span class=\"material-symbols-outlined\">person</span>\n<span class=\"mt-1\">Profile</span>\n</a>\n</nav>\n</main>\n</body></html>"}
