{"screenId":"ffee4c1929624b36964aeca574becdfa","projectId":"3314239195447065678","htmlContent":"<!DOCTYPE html>\n\n<html lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&amp;family=Plus+Jakarta+Sans:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"error\": \"#ba1a1a\",\n              \"inverse-primary\": \"#ffb4a3\",\n              \"inverse-on-surface\": \"#f7efec\",\n              \"primary-fixed-dim\": \"#ffb4a3\",\n              \"on-primary-container\": \"#120100\",\n              \"surface-container-low\": \"#faf2ef\",\n              \"on-tertiary-container\": \"#ffffff\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"on-tertiary\": \"#ffffff\",\n              \"surface-container-highest\": \"#e8e1de\",\n              \"on-surface-variant\": \"#56423d\",\n              \"tertiary-fixed\": \"#f9dec3\",\n              \"background\": \"#fff8f5\",\n              \"tertiary-fixed-dim\": \"#dcc2a9\",\n              \"surface-bright\": \"#fff8f5\",\n              \"on-tertiary-fixed\": \"#261909\",\n              \"on-tertiary-fixed-variant\": \"#554430\",\n              \"inverse-surface\": \"#33302e\",\n              \"secondary-fixed-dim\": \"#adcfb4\",\n              \"on-error\": \"#ffffff\",\n              \"on-surface\": \"#1e1b19\",\n              \"secondary\": \"#466550\",\n              \"surface\": \"#fff8f5\",\n              \"primary\": \"#a03f28\",\n              \"surface-tint\": \"#a03f29\",\n              \"surface-variant\": \"#e8e1de\",\n              \"primary-container\": \"#c0573e\",\n              \"on-secondary-container\": \"#4b6a54\",\n              \"primary-fixed\": \"#ffdad2\",\n              \"surface-container-high\": \"#eee7e4\",\n              \"error-container\": \"#ffdad6\",\n              \"on-secondary-fixed\": \"#022110\",\n              \"outline-variant\": \"#ddc0ba\",\n              \"secondary-container\": \"#c5e8cd\",\n              \"surface-container\": \"#f4ece9\",\n              \"on-secondary-fixed-variant\": \"#2f4d39\",\n              \"on-secondary\": \"#ffffff\",\n              \"surface-dim\": \"#e0d9d6\",\n              \"on-error-container\": \"#93000a\",\n              \"on-background\": \"#1e1b19\",\n              \"on-primary\": \"#ffffff\",\n              \"secondary-fixed\": \"#c8ebd0\",\n              \"outline\": \"#8a726c\",\n              \"on-primary-fixed\": \"#3d0700\",\n              \"on-primary-fixed-variant\": \"#812914\",\n              \"tertiary-container\": \"#88735d\",\n              \"tertiary\": \"#6e5b46\"\n            },\n            fontFamily: {\n              \"headline\": [\"Noto Serif\"],\n              \"body\": [\"Plus Jakarta Sans\"],\n              \"label\": [\"Plus Jakarta Sans\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        body { font-family: 'Plus Jakarta Sans', sans-serif; }\n        h1, h2, h3 { font-family: 'Noto Serif', serif; }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-surface min-h-screen pb-32\">\n<!-- TopAppBar -->\n<header class=\"fixed top-0 w-full z-50 bg-white/80 dark:bg-stone-900/80 backdrop-blur-xl flex items-center justify-between px-6 py-4 w-full\">\n<div class=\"flex items-center gap-4\">\n<button class=\"text-orange-700 dark:text-orange-400 hover:bg-stone-100/50 dark:hover:bg-stone-800/50 transition-colors rounded-full p-2 active:scale-95 duration-200\">\n<span class=\"material-symbols-outlined\" data-icon=\"arrow_back\">arrow_back</span>\n</button>\n<h1 class=\"font-serif text-2xl tracking-tight text-on-surface\">Trip Journal</h1>\n</div>\n<div class=\"font-serif italic text-xl text-stone-900 dark:text-stone-50\">Archive</div>\n</header>\n<main class=\"pt-24 px-6 max-w-3xl mx-auto\">\n<!-- Search Bar -->\n<div class=\"mb-10\">\n<div class=\"relative group\">\n<div class=\"absolute inset-y-0 left-4 flex items-center pointer-events-none\">\n<span class=\"material-symbols-outlined text-outline\" data-icon=\"search\">search</span>\n</div>\n<input class=\"w-full bg-surface-container-low border-none border-b-2 border-surface-container-highest focus:border-primary focus:ring-0 rounded-none py-4 pl-12 pr-4 transition-all duration-300 placeholder:text-stone-400 font-body\" placeholder=\"Search memories...\" type=\"text\"/>\n</div>\n</div>\n<!-- Journal Feed -->\n<div class=\"space-y-12\">\n<!-- Entry 1 -->\n<article class=\"relative group\">\n<div class=\"flex flex-col md:flex-row gap-8 items-start\">\n<div class=\"w-full md:w-1/3 aspect-[4/5] overflow-hidden rounded-xl bg-surface-container-high relative\">\n<img alt=\"Arrival in Zermatt\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" data-alt=\"dramatic snow-capped peaks of the Matterhorn in Zermatt at sunset with a warm orange glow hitting the summit\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAUOYgmPbDAG81MAQybw9cl7B8XFoc_yxqAesIn3UsUsMOn2rpuo88v49i5RVAZXxxC_1GEHJrLE2ay2WHNTeePsSsu_l3ZokUn6cRJUj5_osyHRfeaX0CcF379ZVrRftIgFNAzTj6dsOSLI8SZuWOVOv5TfiT9rZLH-3e74GLAmAGK5Ic9qfVtS7Q1gMrDM11IgR7XxD6XVLTFdB1_v4D2g8RCIuPb8cMeEkwiQCg54s4N0mkH7AXTKF47f04t4Q3P4YeA8pIJYHI\"/>\n<div class=\"absolute top-4 left-4 bg-white/70 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-on-surface\">\n                            July 12, 2026\n                        </div>\n</div>\n<div class=\"w-full md:w-2/3 pt-2\">\n<h2 class=\"text-3xl font-bold leading-tight mb-4 text-on-surface hover:text-primary transition-colors\">Arrival in Zermatt</h2>\n<p class=\"text-on-surface-variant leading-relaxed mb-6 line-clamp-3\">\n                            The air here is different—crisp, thin, and carrying the scent of pine and adventure. As the train pulled into the station, the Matterhorn revealed itself from behind a shroud of mist, a jagged tooth of rock piercing the heavens. We dropped our bags and immediately headed for the trail.\n                        </p>\n<div class=\"flex items-center gap-6 text-outline text-sm font-medium\">\n<div class=\"flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"chat_bubble_outline\">chat_bubble_outline</span>\n<span>12 comments</span>\n</div>\n<div class=\"flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"favorite_border\">favorite_border</span>\n<span>48 reactions</span>\n</div>\n</div>\n</div>\n</div>\n</article>\n<!-- Entry 2 -->\n<article class=\"relative group\">\n<div class=\"flex flex-col md:flex-row-reverse gap-8 items-start\">\n<div class=\"w-full md:w-1/3 aspect-[4/5] overflow-hidden rounded-xl bg-surface-container-high relative\">\n<img alt=\"The Hidden Valley\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" data-alt=\"lush green alpine meadow with colorful wildflowers in the foreground and towering granite cliffs in the background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDszFAmqy2XcAJ_rsibwfgvwlfDxnYBnN5u4HYUSjY0Ln_aPs3dOw6XMi6hR13TPUNHReAvoGiYYgvQkXBwGdrfi0DZu58xRq4R8V4l1J1oocb1KddSmvAkuCr6yK82xffeCHq1nc7d-O8uudNrmJnxqcWAW_Qti55H-Ww02SUsKepngK8peG898njL4HUgJDvG_-7B55a-LB4GT0dUgzXEKow1pRfHog0JqD-8qGVjDsvet1ziF-jq2yvp5Cz_P_cpv-IY7nSprF4\"/>\n<div class=\"absolute top-4 right-4 bg-white/70 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-on-surface\">\n                            July 14, 2026\n                        </div>\n</div>\n<div class=\"w-full md:w-2/3 pt-2\">\n<h2 class=\"text-3xl font-bold leading-tight mb-4 text-on-surface hover:text-primary transition-colors\">The Hidden Valley</h2>\n<p class=\"text-on-surface-variant leading-relaxed mb-6 line-clamp-3\">\n                            Beyond the tourist paths lies a valley where the only sound is the rhythmic clanging of cowbells in the distance. We spent the afternoon tracing the edge of a glacial stream, its water so blue it looked painted. Every corner turned felt like a discovery of a world untouched by time.\n                        </p>\n<div class=\"flex items-center gap-6 text-outline text-sm font-medium\">\n<div class=\"flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"chat_bubble_outline\">chat_bubble_outline</span>\n<span>8 comments</span>\n</div>\n<div class=\"flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"favorite_border\">favorite_border</span>\n<span>34 reactions</span>\n</div>\n</div>\n</div>\n</div>\n</article>\n<!-- Entry 3 -->\n<article class=\"relative group\">\n<div class=\"flex flex-col md:flex-row gap-8 items-start\">\n<div class=\"w-full md:w-1/3 aspect-[4/5] overflow-hidden rounded-xl bg-surface-container-high relative\">\n<img alt=\"Summit Reflections\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" data-alt=\"misty mountain peak at dawn with soft indigo and violet tones and a single silhouetted climber\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBbHeNJ2jk70Oacyy_Ww7gjvpyGwES_5y64o5epkl90NrxNRgoprdgsa7_XIhIldefFLNMReRH4zgG9bCpZQVloL14JirS66GJ5hO1tWpc2EYkvFMhxSwJY8uEIzmxfvdNGidc3NCzus0peJKzmhA-JdDks9-e30S_Fs76Z9E_MaHfTSiaDZNU_CG1SQkrfLrhscTDGaF8jwbfQh_WDbHJX40Ret-lwJTyATdY_M-gvwZVo_XDk3Kuln_7MtXGWPFPfX6w2Vg9k6hU\"/>\n<div class=\"absolute top-4 left-4 bg-white/70 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-on-surface\">\n                            July 15, 2026\n                        </div>\n</div>\n<div class=\"w-full md:w-2/3 pt-2\">\n<h2 class=\"text-3xl font-bold leading-tight mb-4 text-on-surface hover:text-primary transition-colors\">Summit Reflections</h2>\n<p class=\"text-on-surface-variant leading-relaxed mb-6 line-clamp-3\">\n                            Standing at 3,000 meters, the perspective shifts. The worries of the valley floor seem insignificant. We sat in silence for an hour, watching the shadows stretch across the peaks. This is why we travel—to be reminded of how small we are, and how vast the beauty of the world is.\n                        </p>\n<div class=\"flex items-center gap-6 text-outline text-sm font-medium\">\n<div class=\"flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"chat_bubble_outline\">chat_bubble_outline</span>\n<span>21 comments</span>\n</div>\n<div class=\"flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"favorite_border\">favorite_border</span>\n<span>92 reactions</span>\n</div>\n</div>\n</div>\n</div>\n</article>\n</div>\n</main>\n<!-- Floating Action Button -->\n<button class=\"fixed bottom-28 right-8 w-16 h-16 rounded-full bg-gradient-to-br from-primary to-primary-container text-on-primary shadow-[0_20px_40px_rgba(30,27,25,0.15)] flex items-center justify-center active:scale-90 transition-transform z-50 group\">\n<span class=\"material-symbols-outlined text-3xl\" data-icon=\"add\">add</span>\n</button>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full bg-white/80 dark:bg-stone-900/80 backdrop-blur-xl flex justify-around items-center px-4 pb-6 pt-3 z-50 rounded-t-3xl shadow-[0_-10px_40px_rgba(30,27,25,0.04)]\">\n<a class=\"flex flex-col items-center justify-center text-orange-700 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20 rounded-xl px-3 py-1 active:scale-90 transition-transform\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"auto_stories\">auto_stories</span>\n<span class=\"font-sans text-[11px] font-medium tracking-wide uppercase mt-1\">Feed</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-stone-400 dark:text-stone-500 px-3 py-1 hover:text-stone-900 dark:hover:text-stone-100 active:scale-90 transition-transform\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"search\">search</span>\n<span class=\"font-sans text-[11px] font-medium tracking-wide uppercase mt-1\">Search</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-stone-400 dark:text-stone-500 px-3 py-1 hover:text-stone-900 dark:hover:text-stone-100 active:scale-90 transition-transform\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"add_circle\">add_circle</span>\n<span class=\"font-sans text-[11px] font-medium tracking-wide uppercase mt-1\">New</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-stone-400 dark:text-stone-500 px-3 py-1 hover:text-stone-900 dark:hover:text-stone-100 active:scale-90 transition-transform\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-sans text-[11px] font-medium tracking-wide uppercase mt-1\">Profile</span>\n</a>\n</nav>\n</body></html>"}
