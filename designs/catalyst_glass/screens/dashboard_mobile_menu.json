{"screenId":"2088a65992df46488169953db297f443","projectId":"3314239195447065678","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Catalyst Dashboard</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Space+Grotesk:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"on-primary\": \"#ffffff\",\n                        \"surface-dim\": \"#d2d9f4\",\n                        \"tertiary-fixed-dim\": \"#ffb960\",\n                        \"outline-variant\": \"#bdc8d1\",\n                        \"on-tertiary-fixed-variant\": \"#653e00\",\n                        \"primary-fixed-dim\": \"#7bd0ff\",\n                        \"surface\": \"#faf8ff\",\n                        \"tertiary-container\": \"#f1a02b\",\n                        \"surface-container-lowest\": \"#ffffff\",\n                        \"tertiary-fixed\": \"#ffddb8\",\n                        \"inverse-on-surface\": \"#eef0ff\",\n                        \"secondary-fixed\": \"#68fcbf\",\n                        \"surface-container-highest\": \"#dae2fd\",\n                        \"inverse-surface\": \"#283044\",\n                        \"on-surface-variant\": \"#3e484f\",\n                        \"on-surface\": \"#131b2e\",\n                        \"surface-bright\": \"#faf8ff\",\n                        \"error\": \"#ba1a1a\",\n                        \"tertiary\": \"#855300\",\n                        \"on-tertiary-fixed\": \"#2a1700\",\n                        \"surface-tint\": \"#00668a\",\n                        \"secondary-container\": \"#64f9bc\",\n                        \"primary\": \"#00668a\",\n                        \"secondary\": \"#006c4b\",\n                        \"primary-fixed\": \"#c4e7ff\",\n                        \"on-primary-fixed\": \"#001e2c\",\n                        \"on-secondary\": \"#ffffff\",\n                        \"on-tertiary-container\": \"#613b00\",\n                        \"on-primary-container\": \"#004965\",\n                        \"secondary-fixed-dim\": \"#45dfa4\",\n                        \"outline\": \"#6e7980\",\n                        \"surface-container-low\": \"#f2f3ff\",\n                        \"on-tertiary\": \"#ffffff\",\n                        \"on-background\": \"#131b2e\",\n                        \"surface-container\": \"#eaedff\",\n                        \"on-error\": \"#ffffff\",\n                        \"on-secondary-fixed-variant\": \"#005137\",\n                        \"background\": \"#faf8ff\",\n                        \"on-primary-fixed-variant\": \"#004c69\",\n                        \"error-container\": \"#ffdad6\",\n                        \"inverse-primary\": \"#7bd0ff\",\n                        \"surface-container-high\": \"#e2e7ff\",\n                        \"surface-variant\": \"#dae2fd\",\n                        \"on-secondary-container\": \"#00714e\",\n                        \"primary-container\": \"#38bdf8\",\n                        \"on-secondary-fixed\": \"#002114\",\n                        \"on-error-container\": \"#93000a\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Space Grotesk\"],\n                        \"body\": [\"Inter\"],\n                        \"label\": [\"Space Grotesk\"]\n                    },\n                    borderRadius: {\"DEFAULT\": \"1rem\", \"lg\": \"2rem\", \"xl\": \"3rem\", \"full\": \"9999px\"},\n                },\n            },\n        }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #faf8ff;\n            color: #131b2e;\n        }\n        .headline-font { font-family: 'Space Grotesk', sans-serif; }\n        .tonal-sculpting {\n            background: linear-gradient(135deg, rgba(255,255,255,0.8) 0%, rgba(242,243,255,0.6) 100%);\n        }\n        .glass-card {\n            background: rgba(255, 255, 255, 0.7);\n            backdrop-filter: blur(20px) saturate(180%);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n\n        /* Drawer state management */\n        #nav-drawer {\n            transform: translateX(-100%);\n            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n        #nav-drawer.open {\n            transform: translateX(0);\n        }\n        #nav-overlay {\n            opacity: 0;\n            pointer-events: none;\n            transition: opacity 0.3s ease;\n        }\n        #nav-overlay.open {\n            opacity: 1;\n            pointer-events: auto;\n        }\n    </style>\n<style>\n        body {\n            min-height: max(884px, 100dvh);\n        }\n    </style>\n</head>\n<body class=\"min-h-screen flex overflow-x-hidden\">\n<!-- Overlay for Navigation Drawer -->\n<div class=\"fixed inset-0 z-40 bg-slate-900/40 backdrop-blur-sm\" id=\"nav-overlay\" onclick=\"toggleDrawer()\"></div>\n<!-- Navigation Drawer -->\n<nav class=\"fixed inset-y-0 left-0 z-50 flex flex-col bg-[#0b1220] dark:bg-[#0b1220] rounded-r-[2rem] h-full w-72 shadow-[0_20px_40px_-12px_rgba(11,18,32,0.5)] font-['Space_Grotesk'] antialiased tracking-tight\" id=\"nav-drawer\">\n<div class=\"p-8\">\n<div class=\"flex justify-between items-center mb-10\">\n<span class=\"text-2xl font-bold text-white tracking-tighter\">Catalyst</span>\n<button class=\"md:hidden text-white/60 hover:text-white transition-colors\" onclick=\"toggleDrawer()\">\n<span class=\"material-symbols-outlined\">close</span>\n</button>\n</div>\n<!-- Profile Header -->\n<div class=\"flex items-center gap-4 mb-8\">\n<div class=\"w-12 h-12 rounded-2xl overflow-hidden bg-sky-500/20\">\n<img alt=\"User Profile\" class=\"w-full h-full object-cover\" data-alt=\"close-up portrait of a friendly professional man with short dark hair and a warm smile against a neutral studio background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDnXlYXZoZHi7XaWFHJbmJCuL_yYSBLGiLOzrONSYg2boR2BRnVxKTN-sPVF2b8CVHlf7L5w2gAPAIggOSsareoQNqarlnLDMNWqEW7iiA8vwRcESmwzT2fhsKESAXdpT0a1J159ZJKZu2StPwkKg4lj0sw788Ksn7Z7KqNihlZ05NuqB1rz1Vvbk7cDedVqiEAkDAUk0PXXqYVfY7CMK5iiqtthffeekgV2uWuBSL1f_rFx22KFEzbRQfBE6J4S-yUpJDVD5bEmT0\"/>\n</div>\n<div class=\"flex flex-col\">\n<span class=\"text-white font-bold text-lg leading-tight\">Alex Rivers</span>\n<span class=\"text-slate-400 text-xs\">Global Explorer</span>\n</div>\n</div>\n<div class=\"flex flex-col gap-2\">\n<!-- Journal - Active -->\n<a class=\"bg-sky-500/10 text-sky-400 rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 active:scale-[0.98]\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"edit_note\">edit_note</span>\n<span class=\"font-medium\">Journal</span>\n</a>\n<!-- Map -->\n<a class=\"text-slate-400 hover:text-white hover:bg-white/5 rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 active:scale-[0.98]\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"map\">map</span>\n<span class=\"font-medium\">Map</span>\n</a>\n<!-- Memories -->\n<a class=\"text-slate-400 hover:text-white hover:bg-white/5 rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 active:scale-[0.98]\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"photo_library\">photo_library</span>\n<span class=\"font-medium\">Memories</span>\n</a>\n<!-- Discover -->\n<a class=\"text-slate-400 hover:text-white hover:bg-white/5 rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 active:scale-[0.98]\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"explore\">explore</span>\n<span class=\"font-medium\">Discover</span>\n</a>\n</div>\n</div>\n<div class=\"mt-auto p-8\">\n<a class=\"text-slate-400 hover:text-white hover:bg-white/5 rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 active:scale-[0.98]\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"settings\">settings</span>\n<span class=\"font-medium\">Settings</span>\n</a>\n<div class=\"mt-4 px-6 text-[10px] text-slate-500 uppercase tracking-widest font-bold\">\n            128 Entries\n        </div>\n</div>\n</nav>\n<!-- Main Canvas -->\n<main class=\"flex-1 relative overflow-y-auto bg-[#faf8ff]\">\n<!-- Decorative Blurred Blobs -->\n<div class=\"absolute top-0 right-0 -z-10 w-[500px] h-[500px] bg-sky-200/30 rounded-full blur-[120px] -mr-48 -mt-48\"></div>\n<div class=\"absolute bottom-0 left-0 -z-10 w-[400px] h-[400px] bg-indigo-100/40 rounded-full blur-[100px] -ml-24 -mb-24\"></div>\n<!-- Top Bar -->\n<header class=\"fixed top-0 w-full z-40 flex justify-between items-center px-6 h-16 bg-white/70 backdrop-blur-xl font-['Space_Grotesk']\">\n<button class=\"flex items-center justify-center w-10 h-10 rounded-full hover:bg-black/5 transition-colors\" onclick=\"toggleDrawer()\">\n<span class=\"material-symbols-outlined text-on-surface\" data-icon=\"menu\">menu</span>\n</button>\n<h1 class=\"text-xl font-bold text-slate-900\">Trip Journal</h1>\n<div class=\"w-8 h-8 rounded-full bg-sky-500/20 overflow-hidden\">\n<img alt=\"User Avatar\" class=\"w-full h-full object-cover\" data-alt=\"circular profile icon of a man with short hair and a warm expression\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBCSrVnv-tEf4JddRrwWBASia3LE3f8FT2my-CqHiFxe9vm_kdY4lIXMds2T607_mr2w9MHAB5_u5MtCzuEUixjo_JsbkaXDuOZYXhkeJAm7h63c3ebcf00GpmtQ4LXAUEP0m-LaIHAlWJkgNWClyGo2lsmpAN3sJl2gb6I30CDdL4lm2Nl4OcJ5M344q8VBsj0aVK4uNbB7M3XMMdEVdZsue4CW0gVkUYl1qVHQW0DDHw0SOLDzNyhfLmiq7ZnFUjNyN84J5TBswQ\"/>\n</div>\n</header>\n<div class=\"max-w-5xl mx-auto px-6 py-8 mt-16 font-['Space_Grotesk']\">\n<!-- Hero Welcome Section -->\n<section class=\"mb-12\">\n<h1 class=\"text-4xl md:text-5xl font-bold text-on-background tracking-tighter mb-2\">\n                Welcome back, Alex\n            </h1>\n<p class=\"text-on-surface-variant font-body text-lg\">\n                Ready for your next adventure?\n            </p>\n</section>\n<!-- Quick Actions Pill Cluster -->\n<section class=\"flex flex-wrap gap-3 mb-12\">\n<button class=\"flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary to-primary-container text-white rounded-full font-bold shadow-lg shadow-sky-500/20 hover:-translate-y-0.5 transition-all active:scale-95\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"add\">add</span>\n                New Trip\n            </button>\n<button class=\"flex items-center gap-2 px-6 py-3 bg-white text-on-surface border border-outline-variant/15 rounded-full font-medium hover:-translate-y-0.5 transition-all active:scale-95 shadow-sm\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"edit\">edit</span>\n                New Entry\n            </button>\n<button class=\"flex items-center gap-2 px-6 py-3 bg-white text-on-surface border border-outline-variant/15 rounded-full font-medium hover:-translate-y-0.5 transition-all active:scale-95 shadow-sm\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"checklist\">checklist</span>\n                Add Checklist Item\n            </button>\n</section>\n<!-- Active Trip Card & Bento Grid -->\n<div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12\">\n<!-- Large Active Trip Card -->\n<div class=\"lg:col-span-2 group relative overflow-hidden bg-surface-container-lowest rounded-[2rem] shadow-[0_20px_40px_-12px_rgba(19,27,46,0.08)] hover:-translate-y-1 transition-all duration-500\">\n<div class=\"relative h-64 overflow-hidden\">\n<img alt=\"Dolomites\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" data-alt=\"breathtaking panoramic view of jagged limestone peaks in the Dolomites at sunrise with dramatic shadows and golden mist\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCB4kGDDf8b9Mm7CMidntOREkAXjfT2e_AigrjgeoG-6Kdt9mj-28D0KmhK3e8ILkR1PHKdhDH2XGCm65AHk8MhcRSv4acPlt3jHsnW5IqEmewyX7GVy3V2tq-tt90LTMDUetW-z51_rt-rG1TJ4HqHaU7it5BWwvZVqX1lA1j48r37x4_syMQ0H5UKgOWvABUKCEOz7O2RQOY0UjcX_Q5SxqZQrA9QPMtnRabAW7d1bt-fW0Q1_PR36V1GKxPh5NBdDWYTTPISA70\"/>\n<div class=\"absolute top-6 left-6 px-4 py-1.5 bg-secondary text-white text-xs font-bold rounded-full flex items-center gap-1.5 shadow-xl\">\n<span class=\"w-1.5 h-1.5 bg-white rounded-full animate-pulse\"></span>\n                        Started\n                    </div>\n</div>\n<div class=\"p-8\">\n<div class=\"flex justify-between items-start mb-6\">\n<div>\n<h3 class=\"text-2xl font-bold text-on-surface mb-1\">Exploring the Dolomites</h3>\n<p class=\"text-on-surface-variant font-body\">Northern Italy • Oct 2023</p>\n</div>\n<div class=\"flex items-center -space-x-3\">\n<div class=\"w-10 h-10 rounded-full border-4 border-white overflow-hidden bg-slate-200 shadow-sm\">\n<img class=\"w-full h-full object-cover\" data-alt=\"close-up of a smiling young traveler with a beanie in an outdoor mountain setting\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuByRHqgtC1nczG2_tjL8k2CBvkHc6aLZgJCNKPueIB0WeJUUe2_KvdfhpgrWwg58NQy4PVoYgA7RCeyJ4WD0vWlD0u49M6LSTIB9WHRohnGLx0HDgsfuwxD-25RCfQs2RTgfGX1GTzZUdX_GsgjXMy3qpSFUy06tGn-ypRr-H-5fk4ZDoYG0J7UVFApYNrT-ymh17RFa3QDBCsGjD3O0LtQheCpJpqA8HZWg-3P0GUj5HLiU9tis254-9-zstl-Ckh4mbhF6mgwIB4\"/>\n</div>\n<div class=\"w-10 h-10 rounded-full border-4 border-white overflow-hidden bg-slate-200 shadow-sm\">\n<img class=\"w-full h-full object-cover\" data-alt=\"portrait of a woman traveler with a warm scarf looking at the scenery\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDRtMUJIwiaQujBI2TCyllWMTNbVfDN4TBPi6qUO0crrJt9Ki4MWut5MY5XJvBuk_kPaIkxF-NMy7HHMaFBJYo4XI7-nt8yHjJFc4XuOScLozIQk5a4-i7f47LAVjhFAS7Odcai2rZ71JOKQQh7eyWQEe45juIhjaiTBiQpkljda4i10vcjvtSpHM6uDwzoHRlShcKlbk09CMbzBUppCne4M55DTnQTmDyHfKrUdG-QwglT6Yqux0tkHWAXQ9RRviXLpPvIFjjzRdQ\"/>\n</div>\n<div class=\"w-10 h-10 rounded-full border-4 border-white bg-surface-container-high flex items-center justify-center text-[10px] font-bold text-on-surface-variant shadow-sm\">+2</div>\n</div>\n</div>\n<div class=\"grid grid-cols-2 gap-4\">\n<div class=\"p-4 rounded-2xl bg-surface-container-low flex items-center gap-4\">\n<div class=\"p-2 bg-sky-500/10 text-sky-600 rounded-xl\">\n<span class=\"material-symbols-outlined\" data-icon=\"book\">book</span>\n</div>\n<div>\n<p class=\"text-xl font-bold text-on-surface leading-none\">12</p>\n<p class=\"text-xs text-on-surface-variant uppercase tracking-widest font-bold mt-1\">Entries</p>\n</div>\n</div>\n<div class=\"p-4 rounded-2xl bg-surface-container-low flex items-center gap-4\">\n<div class=\"p-2 bg-secondary-container/20 text-secondary rounded-xl\">\n<span class=\"material-symbols-outlined\" data-icon=\"rule\">rule</span>\n</div>\n<div>\n<p class=\"text-xl font-bold text-on-surface leading-none\">3</p>\n<p class=\"text-xs text-on-surface-variant uppercase tracking-widest font-bold mt-1\">Pending</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!-- Jack AI Assistant Card -->\n<div class=\"glass-card rounded-[2rem] p-8 flex flex-col items-center justify-center text-center shadow-[0_20px_40px_-12px_rgba(19,27,46,0.08)] group hover:-translate-y-1 transition-all duration-500\">\n<div class=\"relative mb-6\">\n<div class=\"w-24 h-24 rounded-full bg-gradient-to-tr from-sky-400 to-indigo-500 p-1 shadow-inner group-hover:rotate-12 transition-transform duration-500\">\n<div class=\"w-full h-full rounded-full bg-white overflow-hidden flex items-center justify-center\">\n<img alt=\"Jack AI\" class=\"w-full h-full object-cover\" data-alt=\"clean digital portrait of a friendly AI assistant with soft human-like features and a subtle futuristic aesthetic\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAsx27c8PNOMFNbxVcSu4Ur8Ht5b_9SqeXyPuTVEJ4Bjz5uVfWp5yjG2Szmz_mjrqJULP_aAZtRLk8mtJMgzO3rXSf5zhPOH4szRwRsyw93ogQ_rIASByVSfTZuFbp6gfK40MbcURYCC-minQevlH8KF89I9dkZ82HPmJb24spWymcKSL7iAvoTC8uknUPm-RoCYLf1vqSEhERbHxnK4iwXAFmGzfJzT9ZRH0RpzKQHTHOKnuf784QyIP1kD1VnEAH4A-GFo1DbdYE\"/>\n</div>\n</div>\n<div class=\"absolute -bottom-1 -right-1 w-8 h-8 bg-sky-500 border-4 border-white rounded-full flex items-center justify-center text-white\">\n<span class=\"material-symbols-outlined text-sm\" data-icon=\"bolt\" data-weight=\"fill\" style=\"font-variation-settings: 'FILL' 1;\">bolt</span>\n</div>\n</div>\n<h3 class=\"text-xl font-bold text-on-surface mb-2\">Jack</h3>\n<p class=\"text-on-surface-variant font-body text-sm mb-8 px-4\">\n                    \"The weather in Bolzano is perfect for hiking tomorrow. Shall I update your itinerary?\"\n                </p>\n<button class=\"w-full py-3 bg-on-background text-white rounded-full font-bold hover:opacity-90 transition-opacity active:scale-95 shadow-md\">\n                    Ask Jack\n                </button>\n<div class=\"mt-4 flex gap-2\">\n<span class=\"px-3 py-1 bg-surface-container-high rounded-full text-[10px] font-bold text-on-surface-variant\">PACKING LIST</span>\n<span class=\"px-3 py-1 bg-surface-container-high rounded-full text-[10px] font-bold text-on-surface-variant\">FLIGHT STATUS</span>\n</div>\n</div>\n</div>\n<!-- Recent Memories / Discover Section -->\n<section>\n<div class=\"flex justify-between items-end mb-8\">\n<h2 class=\"text-2xl font-bo