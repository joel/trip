{"screenId":"54035ca46b79467fb781a9d05899b707","projectId":"3314239195447065678","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Settings - Catalyst</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@400;500;600&amp;family=JetBrains+Mono&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"tertiary\": \"#855300\",\n              \"inverse-on-surface\": \"#eef0ff\",\n              \"surface-container-low\": \"#f2f3ff\",\n              \"surface\": \"#faf8ff\",\n              \"secondary-fixed-dim\": \"#45dfa4\",\n              \"on-primary-container\": \"#004965\",\n              \"on-tertiary-fixed\": \"#2a1700\",\n              \"on-error\": \"#ffffff\",\n              \"primary-fixed\": \"#c4e7ff\",\n              \"outline\": \"#6e7980\",\n              \"secondary\": \"#006c4b\",\n              \"inverse-primary\": \"#7bd0ff\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"surface-container-high\": \"#e2e7ff\",\n              \"primary\": \"#00668a\",\n              \"surface-container\": \"#eaedff\",\n              \"background\": \"#faf8ff\",\n              \"surface-dim\": \"#d2d9f4\",\n              \"on-surface-variant\": \"#3e484f\",\n              \"secondary-fixed\": \"#68fcbf\",\n              \"on-secondary-fixed-variant\": \"#005137\",\n              \"inverse-surface\": \"#283044\",\n              \"error-container\": \"#ffdad6\",\n              \"on-primary-fixed-variant\": \"#004c69\",\n              \"primary-container\": \"#38bdf8\",\n              \"on-surface\": \"#131b2e\",\n              \"outline-variant\": \"#bdc8d1\",\n              \"on-tertiary\": \"#ffffff\",\n              \"surface-container-highest\": \"#dae2fd\",\n              \"on-background\": \"#131b2e\",\n              \"secondary-container\": \"#64f9bc\",\n              \"on-secondary-fixed\": \"#002114\",\n              \"on-secondary-container\": \"#00714e\",\n              \"surface-variant\": \"#dae2fd\",\n              \"tertiary-fixed\": \"#ffddb8\",\n              \"on-secondary\": \"#ffffff\",\n              \"tertiary-container\": \"#f1a02b\",\n              \"on-primary\": \"#ffffff\",\n              \"tertiary-fixed-dim\": \"#ffb960\",\n              \"surface-bright\": \"#faf8ff\",\n              \"on-tertiary-fixed-variant\": \"#653e00\",\n              \"error\": \"#ba1a1a\",\n              \"surface-tint\": \"#00668a\",\n              \"on-error-container\": \"#93000a\",\n              \"primary-fixed-dim\": \"#7bd0ff\",\n              \"on-primary-fixed\": \"#001e2c\",\n              \"on-tertiary-container\": \"#613b00\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Inter\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"1rem\", \"lg\": \"2rem\", \"xl\": \"3rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .tonal-sculpting {\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-background font-body antialiased\">\n<!-- TopAppBar -->\n<header class=\"bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl border-b border-white/30 dark:border-slate-800/50 shadow-sm dark:shadow-none fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 w-full\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-sky-500 dark:text-sky-400 cursor-pointer hover:opacity-80 transition-opacity\">menu</span>\n<h1 class=\"font-['Space_Grotesk'] font-bold tracking-tight text-xl font-bold text-slate-900 dark:text-slate-50\">Catalyst</h1>\n</div>\n<div class=\"flex items-center gap-3\">\n<div class=\"w-8 h-8 rounded-full overflow-hidden bg-surface-container-highest ring-2 ring-primary-container/20\">\n<img alt=\"User profile avatar\" data-alt=\"minimalist 3D avatar of a person with stylish glasses and a friendly expression on a soft blue background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuA5KrCwGL_TgHfN_aB7xdSoe19rLlZCI_OzGpDXCEv9_gtl_cry1kBo-RFPr99HMVNiI7L1woOxtyYnUBisdV5eQvevA0RmVJKJvMl25gYPO312IAZ8CGFobaQdpjvYnM4frFjNJhmrVTeBm8J14rYoUlr36TUbb3RLnCsn9p2ynEkrfXhqfmWSeLsERv-JpOW7BYT7VEr6iUo7luzZt251dPqdg3Ud7rvAXHXQGt3pY0_hazbdLlypJUkW-z6ZwUFTrsiNBteLFpE\"/>\n</div>\n</div>\n</header>\n<main class=\"pt-24 pb-32 px-6 max-w-3xl mx-auto\">\n<!-- Profile Overview Section -->\n<section class=\"mb-12 text-center md:text-left flex flex-col md:flex-row items-center gap-8 bg-surface-container-low p-8 rounded-lg\">\n<div class=\"relative group\">\n<div class=\"w-32 h-32 rounded-full overflow-hidden shadow-xl ring-4 ring-white dark:ring-slate-800\">\n<img class=\"w-full h-full object-cover\" data-alt=\"modern 3D avatar of a profile with sleek features and a soft studio lighting profile portrait\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCX1EQN34rLaz6zz-k_heWpfjstinumT6AxPTSxJXnooZJKqvZ-porAzftfgmERVeHr3XirBuj9DQ1jB2JSBwIhaTjuI8ex00P2_cyprKxXqTfciXSDMiLuRENeYAnDckRVXS-l8NeylTKWSTZAUhqmn0nxiPtDvWJGvb7z8R4f8ZbjAONYYtJrEtiYeb-ZKGvMjzLUTp9Y-ZOYaYqohbIyBrhJOupai5GHMQ3yHkL5V64FUAJ3L7cTspav5qjTx3d43eKzwITRGE0\"/>\n</div>\n<button class=\"absolute bottom-0 right-0 bg-primary text-on-primary p-2 rounded-full shadow-lg hover:scale-105 active:scale-95 transition-transform\">\n<span class=\"material-symbols-outlined text-sm\">edit</span>\n</button>\n</div>\n<div class=\"flex-1\">\n<h2 class=\"font-headline text-3xl font-bold tracking-tight mb-1 text-on-surface\">Adventurer</h2>\n<p class=\"text-on-surface-variant font-medium mb-4\">Premium Member • Joined June 2023</p>\n<div class=\"flex flex-wrap gap-2 justify-center md:justify-start\">\n<span class=\"bg-secondary-container text-on-secondary-container px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider font-label\">Pro Account</span>\n<span class=\"bg-primary-container/20 text-primary px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider font-label\">Beta Tester</span>\n</div>\n</div>\n<button class=\"px-6 py-3 bg-surface-container-lowest text-primary font-bold rounded-full shadow-sm hover:shadow-md transition-shadow border border-outline-variant/10\">\n                Edit Profile\n            </button>\n</section>\n<!-- Settings Categories -->\n<div class=\"space-y-4\">\n<!-- Category Item -->\n<div class=\"group bg-surface-container-lowest p-6 rounded-lg tonal-sculpting hover:bg-surface-container transition-colors cursor-pointer flex items-center justify-between\">\n<div class=\"flex items-center gap-5\">\n<div class=\"w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined\">person_outline</span>\n</div>\n<div>\n<h3 class=\"font-headline font-semibold text-lg text-on-surface\">Profile Information</h3>\n<p class=\"text-on-surface-variant text-sm font-body\">Manage your personal details and display preferences</p>\n</div>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors\">chevron_right</span>\n</div>\n<!-- Category Item -->\n<div class=\"group bg-surface-container-lowest p-6 rounded-lg tonal-sculpting hover:bg-surface-container transition-colors cursor-pointer flex items-center justify-between\">\n<div class=\"flex items-center gap-5\">\n<div class=\"w-12 h-12 rounded-2xl bg-secondary/10 flex items-center justify-center text-secondary\">\n<span class=\"material-symbols-outlined\">passkey</span>\n</div>\n<div>\n<h3 class=\"font-headline font-semibold text-lg text-on-surface\">Security &amp; Passkeys</h3>\n<p class=\"text-on-surface-variant text-sm font-body\">Biometric settings, password, and active sessions</p>\n</div>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:text-secondary transition-colors\">chevron_right</span>\n</div>\n<!-- Category Item -->\n<div class=\"group bg-surface-container-lowest p-6 rounded-lg tonal-sculpting hover:bg-surface-container transition-colors cursor-pointer flex items-center justify-between\">\n<div class=\"flex items-center gap-5\">\n<div class=\"w-12 h-12 rounded-2xl bg-tertiary-container/20 flex items-center justify-center text-tertiary\">\n<span class=\"material-symbols-outlined\">notifications_active</span>\n</div>\n<div>\n<h3 class=\"font-headline font-semibold text-lg text-on-surface\">Notification Preferences</h3>\n<p class=\"text-on-surface-variant text-sm font-body\">Configure alerts for trips, journal updates, and marketing</p>\n</div>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:text-tertiary transition-colors\">chevron_right</span>\n</div>\n<!-- Category Item -->\n<div class=\"group bg-surface-container-lowest p-6 rounded-lg tonal-sculpting hover:bg-surface-container transition-colors cursor-pointer flex items-center justify-between\">\n<div class=\"flex items-center gap-5\">\n<div class=\"w-12 h-12 rounded-2xl bg-on-surface-variant/5 flex items-center justify-center text-on-surface-variant\">\n<span class=\"material-symbols-outlined\">file_download</span>\n</div>\n<div>\n<h3 class=\"font-headline font-semibold text-lg text-on-surface\">Data Export</h3>\n<p class=\"text-on-surface-variant text-sm font-body\">Download your archives in EPUB or ZIP format</p>\n</div>\n</div>\n<div class=\"flex items-center gap-3\">\n<div class=\"hidden sm:flex gap-1\">\n<span class=\"px-2 py-0.5 rounded-md bg-surface-container-high text-[10px] font-bold font-mono text-outline uppercase\">EPUB</span>\n<span class=\"px-2 py-0.5 rounded-md bg-surface-container-high text-[10px] font-bold font-mono text-outline uppercase\">ZIP</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:text-on-surface transition-colors\">chevron_right</span>\n</div>\n</div>\n</div>\n<!-- Logout Section -->\n<div class=\"mt-12 flex justify-center\">\n<button class=\"flex items-center gap-2 px-10 py-4 bg-error-container text-on-error-container font-headline font-bold rounded-full hover:bg-error hover:text-on-error transition-all duration-300 shadow-lg shadow-error/10 active:scale-95\">\n<span class=\"material-symbols-outlined\">logout</span>\n                Logout\n            </button>\n</div>\n</main>\n<!-- NavigationDrawer (Large Screen Only) -->\n<nav class=\"hidden md:flex flex-col p-4 fixed left-0 top-0 h-full z-[60] h-full w-64 rounded-r-3xl bg-slate-900 dark:bg-black shadow-2xl tonal-sculpting gap-2 font-['Space_Grotesk'] text-sm font-medium\">\n<div class=\"p-6 mb-8 flex items-center gap-4\">\n<div class=\"w-10 h-10 rounded-full bg-sky-500/20 flex items-center justify-center text-sky-400\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">explore</span>\n</div>\n<div>\n<p class=\"text-sky-400 font-bold text-lg\">Catalyst</p>\n<p class=\"text-slate-500 text-xs\">Navigation</p>\n</div>\n</div>\n<div class=\"space-y-2\">\n<a class=\"text-slate-400 hover:text-slate-100 px-4 py-3 flex items-center gap-3 hover:bg-slate-800 transition-colors rounded-xl\" href=\"#\">\n<span class=\"material-symbols-outlined\">home</span>\n                Home\n            </a>\n<a class=\"text-slate-400 hover:text-slate-100 px-4 py-3 flex items-center gap-3 hover:bg-slate-800 transition-colors rounded-xl\" href=\"#\">\n<span class=\"material-symbols-outlined\">explore</span>\n                Trips\n            </a>\n<a class=\"text-slate-400 hover:text-slate-100 px-4 py-3 flex items-center gap-3 hover:bg-slate-800 transition-colors rounded-xl\" href=\"#\">\n<span class=\"material-symbols-outlined\">edit_note</span>\n                Journal\n            </a>\n<a class=\"bg-sky-500/10 text-sky-400 rounded-full px-4 py-3 flex items-center gap-3\" href=\"#\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">settings</span>\n                Settings\n            </a>\n</div>\n<div class=\"mt-auto p-4 bg-slate-800/50 rounded-2xl flex items-center gap-3\">\n<div class=\"w-10 h-10 rounded-full overflow-hidden bg-slate-700\">\n<img alt=\"User profile\" data-alt=\"close-up minimalist 3D profile picture of a happy adventurer on dark background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBfnlhuUfmg9WeYWPNfyo96I8UQABTD_S2sZxIQSvlVHOPnEzZYmSsG2v14w9SR8R_v_GuLzyiIOoU-cJKLOjkMlZSfzY9QIF7XIUC4CU9r-0ckqv-eb8u80FN3gDGuIj7pcWhojmCwqASavSz-aDtGqf_RFy7YyTpGRyyipWfVlMZOLnAQVk6luscyydMNJ4hQ7Bi9nOWRLO1XMVCTKIkRA4Ow83_r-EbsY9JDW1Fd8XSG2pMgbzuQ_holQtFOvOSlFMx2RKMnF6M\"/>\n</div>\n<div class=\"overflow-hidden\">\n<p class=\"text-white font-bold truncate\">Adventurer</p>\n<p class=\"text-slate-500 text-xs truncate\">Premium Member</p>\n</div>\n</div>\n</nav>\n<!-- BottomNavBar (Mobile Only) -->\n<nav class=\"md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 dark:bg-slate-950/80 backdrop-blur-lg rounded-t-[2.5rem] shadow-[0_-10px_40px_-12px_rgba(0,0,0,0.1)]\">\n<div class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 px-5 py-2 hover:text-sky-400 transition-all font-['Inter'] text-[10px] font-semibold uppercase tracking-widest\">\n<span class=\"material-symbols-outlined mb-1\">home</span>\n<span>Home</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 px-5 py-2 hover:text-sky-400 transition-all font-['Inter'] text-[10px] font-semibold uppercase tracking-widest\">\n<span class=\"material-symbols-outlined mb-1\">explore</span>\n<span>Trips</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 px-5 py-2 hover:text-sky-400 transition-all font-['Inter'] text-[10px] font-semibold uppercase tracking-widest\">\n<span class=\"material-symbols-outlined mb-1\">edit_note</span>\n<span>Journal</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-sky-500 dark:text-sky-400 bg-sky-50 dark:bg-sky-900/20 rounded-full px-5 py-2 font-['Inter'] text-[10px] font-semibold uppercase tracking-widest active:translate-y-[-2px] transition-transform\">\n<span class=\"material-symbols-outlined mb-1\" style=\"font-variation-settings: 'FILL' 1;\">settings</span>\n<span>Settings</span>\n</div>\n</nav>\n</body></html>"}
