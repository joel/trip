{"screenId":"5a8a2fd4b6f9437c9ec899b419289e89","projectId":"3314239195447065678","htmlContent":"<html class=\"light\" lang=\"en\"><head></head><body class=\"font-body selection:bg-primary-container selection:text-on-primary-container overflow-x-hidden\">```html\n\n\n\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"on-primary\": \"#ffffff\",\n              \"surface-dim\": \"#d2d9f4\",\n              \"tertiary-fixed-dim\": \"#ffb960\",\n              \"outline-variant\": \"#bdc8d1\",\n              \"on-tertiary-fixed-variant\": \"#653e00\",\n              \"primary-fixed-dim\": \"#7bd0ff\",\n              \"surface\": \"#faf8ff\",\n              \"tertiary-container\": \"#f1a02b\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"tertiary-fixed\": \"#ffddb8\",\n              \"inverse-on-surface\": \"#eef0ff\",\n              \"secondary-fixed\": \"#68fcbf\",\n              \"surface-container-highest\": \"#dae2fd\",\n              \"inverse-surface\": \"#283044\",\n              \"on-surface-variant\": \"#3e484f\",\n              \"on-surface\": \"#131b2e\",\n              \"surface-bright\": \"#faf8ff\",\n              \"error\": \"#ba1a1a\",\n              \"tertiary\": \"#855300\",\n              \"on-tertiary-fixed\": \"#2a1700\",\n              \"surface-tint\": \"#00668a\",\n              \"secondary-container\": \"#64f9bc\",\n              \"primary\": \"#00668a\",\n              \"secondary\": \"#006c4b\",\n              \"primary-fixed\": \"#c4e7ff\",\n              \"on-primary-fixed\": \"#001e2c\",\n              \"on-secondary\": \"#ffffff\",\n              \"on-tertiary-container\": \"#613b00\",\n              \"on-primary-container\": \"#004965\",\n              \"secondary-fixed-dim\": \"#45dfa4\",\n              \"outline\": \"#6e7980\",\n              \"surface-container-low\": \"#f2f3ff\",\n              \"on-tertiary\": \"#ffffff\",\n              \"on-background\": \"#131b2e\",\n              \"surface-container\": \"#eaedff\",\n              \"on-error\": \"#ffffff\",\n              \"on-secondary-fixed-variant\": \"#005137\",\n              \"background\": \"#faf8ff\",\n              \"on-primary-fixed-variant\": \"#004c69\",\n              \"error-container\": \"#ffdad6\",\n              \"inverse-primary\": \"#7bd0ff\",\n              \"surface-container-high\": \"#e2e7ff\",\n              \"surface-variant\": \"#dae2fd\",\n              \"on-secondary-container\": \"#00714e\",\n              \"primary-container\": \"#38bdf8\",\n              \"on-secondary-fixed\": \"#002114\",\n              \"on-error-container\": \"#93000a\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Inter\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"1rem\", \"lg\": \"2rem\", \"xl\": \"3rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .tonal-sculpting {\n            background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(242,243,255,1) 100%);\n        }\n        .glass-card {\n            backdrop-filter: blur(12px) saturate(180%);\n            background-color: rgba(255, 255, 255, 0.7);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n        body {\n            background-color: #faf8ff;\n            color: #131b2e;\n            -webkit-font-smoothing: antialiased;\n        }\n\n        /* Drawer functionality */\n        #nav-drawer {\n            transform: translateX(-100%);\n            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n        #nav-drawer.open {\n            transform: translateX(0);\n        }\n        #drawer-backdrop {\n            opacity: 0;\n            pointer-events: none;\n            transition: opacity 0.3s ease;\n        }\n        #drawer-backdrop.open {\n            opacity: 1;\n            pointer-events: auto;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n<!-- NAVIGATION DRAWER BACKDROP -->\n<div class=\"fixed inset-0 bg-black/60 backdrop-blur-sm z-[60]\" id=\"drawer-backdrop\" onclick=\"toggleDrawer()\"></div>\n<!-- NAVIGATION DRAWER -->\n<aside class=\"fixed inset-y-0 left-0 z-[70] flex flex-col bg-[#0b1220] rounded-r-[2rem] h-full w-72 shadow-[0_20px_40px_-12px_rgba(11,18,32,0.5)] font-['Space_Grotesk'] antialiased tracking-tight\" id=\"nav-drawer\">\n<div class=\"p-8 flex items-center justify-between\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-2xl bg-gradient-to-br from-primary to-primary-container flex items-center justify-center text-white text-2xl font-bold tracking-tighter\">C</div>\n<div class=\"flex flex-col\">\n<span class=\"text-xl font-bold text-white tracking-tighter\">Alex Rivers</span>\n<span class=\"text-xs text-slate-400\">Global Explorer</span>\n</div>\n</div>\n<button class=\"text-slate-400 hover:text-white transition-colors\" onclick=\"toggleDrawer()\">\n<span class=\"material-symbols-outlined\">close</span>\n</button>\n</div>\n<nav class=\"flex-1 px-4 space-y-2 mt-4\">\n<a class=\"bg-sky-500/10 text-sky-400 rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"edit_note\">edit_note</span>\n<span class=\"font-medium\">Journal</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"map\">map</span>\n<span class=\"font-medium\">Map</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"photo_library\">photo_library</span>\n<span class=\"font-medium\">Memories</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"explore\">explore</span>\n<span class=\"font-medium\">Discover</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5 mt-auto\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"settings\">settings</span>\n<span class=\"font-medium\">Settings</span>\n</a>\n</nav>\n<div class=\"p-6 mt-auto border-t border-white/5\">\n<div class=\"bg-white/5 rounded-2xl p-4\">\n<p class=\"text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-1\">Status</p>\n<p class=\"text-white text-sm font-medium\">128 Entries</p>\n</div>\n</div>\n</aside>\n<!-- TOP APP BAR -->\n<header class=\"fixed top-0 w-full z-40 flex justify-between items-center px-6 h-16 bg-white/70 backdrop-blur-xl border-b border-surface-container\">\n<div class=\"flex items-center gap-4\">\n<button class=\"flex items-center justify-center w-10 h-10 rounded-full hover:bg-surface-container transition-colors text-on-surface\" onclick=\"toggleDrawer()\">\n<span class=\"material-symbols-outlined\" data-icon=\"menu\">menu</span>\n</button>\n<span class=\"text-xl font-bold text-on-surface font-headline tracking-tight\">Trip Journal</span>\n</div>\n<div class=\"w-8 h-8 rounded-full bg-surface-container overflow-hidden\">\n<img alt=\"User Avatar\" class=\"w-full h-full object-cover\" data-alt=\"Close-up portrait of a man with a friendly expression and short dark hair in high-key studio lighting\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDSlLLA8D9Fey3GKp25lx45mOrDMbF7nL-VkWO8k_gLUPl8Gzx0Sc9A8D5rJ6B4SzFWz2jZR--Mh2GKkTlt-WehIHqy99T1GFGt9Bo35qqEmZD5nxu0v7317rqQoD3eByRGm1IKNdzuGUrC6po_636tf9oxvT7iNrahatqg7Hk8EeJZcNRfkEZBuGKbjsWZmHCvRNorIASSJxoN5Rw7QteNDzCdMDymBS_H_DqmCEs8Vp985o0dzP5X2sUNyXU6JpES-GmLYMxAgSA\"/>\n</div>\n</header>\n<!-- MAIN CANVAS -->\n<main class=\"min-h-screen relative pt-16\">\n<!-- Abstract Background Blobs -->\n<div class=\"fixed top-[-10%] right-[-10%] w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px] -z-10\"></div>\n<div class=\"fixed bottom-[-5%] left-[20%] w-[400px] h-[400px] bg-secondary/10 rounded-full blur-[100px] -z-10\"></div>\n<div class=\"max-w-5xl mx-auto px-6 py-12\">\n<!-- Header Section -->\n<header class=\"flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16\">\n<div class=\"space-y-2\">\n<h1 class=\"text-5xl font-bold font-headline tracking-tighter text-on-surface\">My Trips</h1>\n<p class=\"text-on-surface-variant font-medium\">Documenting the world, one journey at a time.</p>\n</div>\n<div class=\"flex flex-wrap items-center gap-4\">\n<div class=\"relative group flex-1 md:flex-initial\">\n<span class=\"material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors\">search</span>\n<input class=\"w-full md:w-64 bg-surface-container-highest border-none rounded-[16px] pl-12 pr-4 py-3 focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all font-body text-sm outline-none\" placeholder=\"Search destinations...\" type=\"text\"/>\n</div>\n<button class=\"bg-gradient-to-br from-primary to-primary-container text-on-primary px-8 py-3.5 rounded-full font-headline font-bold text-sm tracking-wide shadow-lg shadow-primary/20 hover:translate-y-[-1px] transition-all flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-base\">add</span>\n                        New Trip\n                    </button>\n</div>\n</header>\n<!-- Grid of TripCards -->\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n<!-- Card 1: Dolomites -->\n<div class=\"group relative bg-surface-container-lowest rounded-lg overflow-hidden transition-all duration-300 hover:translate-y-[-4px] hover:shadow-[0_20px_40px_-12px_rgba(19,27,46,0.12)] cursor-pointer\">\n<div class=\"aspect-[16/10] overflow-hidden\">\n<img alt=\"Dolomites\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" data-alt=\"Stunning cinematic wide shot of the Italian Dolomites jagged peaks at sunrise with dramatic low clouds and orange light\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCzdWRjh0QzX6yHACNwO6Z-vmGWg-w7ksc0D4x66m1JC3P0tYfM-VJrYVLLRhFETCPzkg6coNhpKIofDmuzVcRm8vaOdYFgvxOPl3bwfaFuDE5MphRCsKGSne-F6DflYQjC5TjFRcDje4QQ4XzD_oGpE3_C98n2Cm-xPm9mgwvIK7kKKazycctu8geVV2-gi8DnLfrKWYPgvM4Dl-cm-u28_Rb1IusyBSv_9X0-2V4IEBN9V6jCwNrrhHJkk-R6pI1LgfTv_9FeAJI\"/>\n</div>\n<div class=\"p-8 space-y-4\">\n<div class=\"flex justify-between items-start\">\n<span class=\"inline-flex items-center px-3 py-1 rounded-full bg-secondary-container text-on-secondary-container text-[10px] font-bold uppercase tracking-widest\">Started</span>\n<span class=\"text-outline text-xs font-mono\">2024.08.12</span>\n</div>\n<h3 class=\"text-2xl font-bold font-headline tracking-tight text-on-surface\">Dolomites Expedition</h3>\n<p class=\"text-on-surface-variant text-sm leading-relaxed\">High-altitude traversing through the Seceda ridgeline and Alpe di Siusi alpine meadows.</p>\n<div class=\"pt-4 flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-widest group-hover:gap-4 transition-all\">\n                            View details\n                            <span class=\"material-symbols-outlined text-sm\">arrow_forward</span>\n</div>\n</div>\n</div>\n<!-- Card 2: Tokyo -->\n<div class=\"group relative bg-surface-container-lowest rounded-lg overflow-hidden transition-all duration-300 hover:translate-y-[-4px] hover:shadow-[0_20px_40px_-12px_rgba(19,27,46,0.12)] cursor-pointer\">\n<div class=\"aspect-[16/10] overflow-hidden\">\n<img alt=\"Tokyo\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" data-alt=\"Vibrant night scene of Tokyo Shinjuku district with neon lights reflected on wet asphalt street and blurred city motion\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAJbdB5_2gFYb5hFt7phdrXPTqQnGbkLVWalrzsOZOL2URkhOPkRPfY4L8iWA2AmQYd9nJzPWSpQGM4x8IvQUWY1EcACZeWN7IU2PKnaU2w07ELtiLXoEaGZORKLaba4SgRCH3MbQWfsAkzCS8A4qPdk5LSklmAshfMrrBLQy6Qos9Vw_Uf2wR4cf9CerkRpnCU5-ALt7S7kBkLRJQKqIBDeMg3p57pvIve-TG8DDh1IzoPS_u08BSfpilu_l4DjvOm3ulmVK7LZR8\"/>\n</div>\n<div class=\"p-8 space-y-4\">\n<div class=\"flex justify-between items-start\">\n<span class=\"inline-flex items-center px-3 py-1 rounded-full bg-primary-container/20 text-primary text-[10px] font-bold uppercase tracking-widest\">Planning</span>\n<span class=\"text-outline text-xs font-mono\">2024.11.05</span>\n</div>\n<h3 class=\"text-2xl font-bold font-headline tracking-tight text-on-surface\">Tokyo City Lights</h3>\n<p class=\"text-on-surface-variant text-sm leading-relaxed\">Exploring the intersection of tradition and futurism across Shibuya, Akihabara, and historic Kyoto.</p>\n<div class=\"pt-4 flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-widest group-hover:gap-4 transition-all\">\n                            View details\n                            <span class=\"material-symbols-outlined text-sm\">arrow_forward</span>\n</div>\n</div>\n</div>\n<!-- Card 3: Amalfi -->\n<div class=\"group relative bg-surface-container-lowest rounded-lg overflow-hidden transition-all duration-300 hover:translate-y-[-4px] hover:shadow-[0_20px_40px_-12px_rgba(19,27,46,0.12)] cursor-pointer\">\n<div class=\"aspect-[16/10] overflow-hidden\">\n<img alt=\"Amalfi\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" data-alt=\"Picturesque coastal view of Positano on the Amalfi Coast with pastel colored houses stacked on a cliff overlooking deep blue Mediterranean sea\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuD7p6Y8YAtGFxo8qCAHD66KZspzXYtUmX18XdvprCigR401bvHy6EiWL3eGSeD4xetffSwdRYmUOpTSNEghJZYsw-IfJyNS1qpzS7ZS8jYqBeKfX6FKX8Z0NnXBdnqXhjBYdkfCFkQfxDWsKHOeumZxE1mpsAqn9Fm9h4Vgpfsj19MEq1LsWiXCYl_XrQaaIEpazI71kfQjTySUnK56AQXxPBn-tEbxS_Szoe2heHN8KNXOlz2RRdT5JLUWy2_6dcbWYier0XTQQ0U\"/>\n</div>\n<div class=\"p-8 space-y-4\">\n<div class=\"flex justify-between items-start\">\n<span class=\"inline-flex items-center px-3 py-1 rounded-full bg-surface-variant text-on-surface-variant text-[10px] font-bold uppercase tracking-widest\">Finished</span>\n<span class=\"text-outline text-xs font-mono\">2023.06.20</span>\n</div>\n<h3 class=\"text-2xl font-bold font-headline tracking-tight text-on-surface\">Amalfi Coast</h3>\n<p class=\"text-on-surface-variant text-sm leading-relaxed\">A summer journey through the dramatic cliffs of southern Italy, lemon groves, and azure waters.</p>\n<div class=\"pt-4 flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-widest group-hover:gap-4 transition-all\">\n                            View details\n                            <span class=\"material-symbols-outlined text-sm\">arrow_forward</span>\n</div>\n</div>\n</div>\n<!-- Card 4: Cancelled -->\n<div class=\"group relative bg-surface-container-lowest rounded-lg overflow-hidden transition-all duration-300 hover:translate-y-[-4px] hover:shadow-[0_20px_40px_-12px_rgba(19,27,46,0.12)] cursor-pointer\">\n<div class=\"aspect-[16/10] overflow-hidden grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500\">\n<img alt=\"Desert\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" data-alt=\"Vast cinematic landscape of orange sand dunes in the Sahara desert under a clear blue sky with sharp ridges and deep shadows\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBSne2mcMsspzyC56PqUCUFzuVQmge0FXcr7rrQi5DkTGnUeicRDrIixlYChANNmBayAg7H8tfwSMi-7sBiS1i4hISLlC9rlP0UQwirC5DygZ7I-bzpImsDYHVRSlatiC9mO559L94Y5-0wlaoWwxDpYQuzXWr8azXYmDzREN84JmM6lUrtFdlvwf8-jdwzCAjwruxemtEPBbwUgDCl8-s17Yzq30iow9gUPYoemLa4tA8raMQ6KOCzOouXHdgdgHb1OivYsiiuEIk\"/>\n</div>\n<div class=\"p-8 space-y-4\">\n<div class=\"flex justify-between items-start\">\n<span class=\"inline-flex items-center px-3 py-1 rounded-full bg-error-container text-on-error-container text-[10px] font-bold uppercase tracking-widest\">Cancelled</span>\n<span class=\"text-outline text-xs font-mono\">2023.10.15</span>\n</div>\n<h3 class=\"text-2xl font-bold font-headline tracking-tight text-on-surface\">Cancelled Trip</h3>\n<p class=\"text-on-surface-variant text-sm leading-relaxed\">Saharan expedition through Morocco. Trip deferred due to local logistics issues.</p>\n<div class=\"pt-4 flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-widest group-hover:gap-4 transition-all\">\n                            View details\n                            <span class=\"material-symbols-outlined text-sm\">arrow_forward</span>\n</div>\n</div>\n</div>\n</div>\n<!-- Empty State / Footer Tonal Shift -->\n<footer class=\"mt-24 py-12 text-center border-t border-surface-container\">\n<p class=\"font-headline font-bold text-on-surface-variant opacity-30 text-8xl select-none\">EXPLORE</p>\n</footer>\n</div>\n</main>\n<!-- BOTTOM NAVBAR (MOBILE ONLY) -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 dark:bg-white/10 backdrop-blur-2xl border-t border-white/20 md:hidden\">\n<a class=\"flex flex-col items-center justify-center text-sky-500 font-bold scale-110\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"home\">home</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest mt-1\">Home</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-slate-400\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"draw\">draw</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest mt-1\">Drafts</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-slate-400\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"bookmark\">bookmark</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest mt-1\">Saved</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-slate-400\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest mt-1\">Profile</span>\n</a>\n</nav>\n<script>\n    function toggleDrawer() {\n        const drawer = document.getElementById('nav-drawer');\n        const backdrop = document.getElementById('drawer-backdrop');\n        drawer.classList.toggle('open');\n        backdrop.classList.toggle('open');\n        \n        // Prevent body scroll when drawer is open\n        if (drawer.classList.contains('open')) {\n            document.body.style.overflow = 'hidden';\n        } else {\n            document.body.style.overflow = '';\n        }\n    }\n</script>\n```</body></html>"}
