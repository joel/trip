{"screenId":"a92043ac2d344078a6674b6f81d228d4","projectId":"3314239195447065678","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Catalyst | Collaboration Hub</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"tertiary\": \"#855300\",\n              \"inverse-on-surface\": \"#eef0ff\",\n              \"surface-container-low\": \"#f2f3ff\",\n              \"surface\": \"#faf8ff\",\n              \"secondary-fixed-dim\": \"#45dfa4\",\n              \"on-primary-container\": \"#004965\",\n              \"on-tertiary-fixed\": \"#2a1700\",\n              \"on-error\": \"#ffffff\",\n              \"primary-fixed\": \"#c4e7ff\",\n              \"outline\": \"#6e7980\",\n              \"secondary\": \"#006c4b\",\n              \"inverse-primary\": \"#7bd0ff\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"surface-container-high\": \"#e2e7ff\",\n              \"primary\": \"#00668a\",\n              \"surface-container\": \"#eaedff\",\n              \"background\": \"#faf8ff\",\n              \"surface-dim\": \"#d2d9f4\",\n              \"on-surface-variant\": \"#3e484f\",\n              \"secondary-fixed\": \"#68fcbf\",\n              \"on-secondary-fixed-variant\": \"#005137\",\n              \"inverse-surface\": \"#283044\",\n              \"error-container\": \"#ffdad6\",\n              \"on-primary-fixed-variant\": \"#004c69\",\n              \"primary-container\": \"#38bdf8\",\n              \"on-surface\": \"#131b2e\",\n              \"outline-variant\": \"#bdc8d1\",\n              \"on-tertiary\": \"#ffffff\",\n              \"surface-container-highest\": \"#dae2fd\",\n              \"on-background\": \"#131b2e\",\n              \"secondary-container\": \"#64f9bc\",\n              \"on-secondary-fixed\": \"#002114\",\n              \"on-secondary-container\": \"#00714e\",\n              \"surface-variant\": \"#dae2fd\",\n              \"tertiary-fixed\": \"#ffddb8\",\n              \"on-secondary\": \"#ffffff\",\n              \"tertiary-container\": \"#f1a02b\",\n              \"on-primary\": \"#ffffff\",\n              \"tertiary-fixed-dim\": \"#ffb960\",\n              \"surface-bright\": \"#faf8ff\",\n              \"on-tertiary-fixed-variant\": \"#653e00\",\n              \"error\": \"#ba1a1a\",\n              \"surface-tint\": \"#00668a\",\n              \"on-error-container\": \"#93000a\",\n              \"primary-fixed-dim\": \"#7bd0ff\",\n              \"on-primary-fixed\": \"#001e2c\",\n              \"on-tertiary-container\": \"#613b00\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Inter\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"1rem\", \"lg\": \"2rem\", \"xl\": \"3rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.7);\n            backdrop-filter: blur(20px) saturate(180%);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n        .aura-shadow {\n            box-shadow: 0 20px 40px -12px rgba(19, 27, 46, 0.08);\n        }\n        .primary-gradient {\n            background: linear-gradient(135deg, #00668a, #38bdf8);\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background font-body text-on-surface\">\n<!-- TopAppBar -->\n<header class=\"fixed top-0 w-full z-50 bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl border-b border-white/30 dark:border-slate-800/50 shadow-sm dark:shadow-none flex justify-between items-center px-6 h-16 w-full\">\n<div class=\"flex items-center gap-4\">\n<button class=\"text-sky-500 dark:text-sky-400 hover:opacity-80 transition-opacity active:scale-95 duration-200\">\n<span class=\"material-symbols-outlined\" data-icon=\"menu\">menu</span>\n</button>\n<h1 class=\"font-['Space_Grotesk'] font-bold tracking-tight text-xl text-slate-900 dark:text-slate-50\">Catalyst</h1>\n</div>\n<div class=\"flex items-center gap-6\">\n<nav class=\"hidden md:flex gap-8\">\n<a class=\"text-slate-500 font-medium hover:opacity-80 transition-opacity\" href=\"#\">Home</a>\n<a class=\"text-sky-600 font-bold border-b-2 border-sky-600 pb-1\" href=\"#\">Team</a>\n<a class=\"text-slate-500 font-medium hover:opacity-80 transition-opacity\" href=\"#\">Journal</a>\n</nav>\n<div class=\"h-10 w-10 rounded-full overflow-hidden border-2 border-primary-container\">\n<img alt=\"User profile\" data-alt=\"close-up portrait of a professional man with a friendly expression in a brightly lit modern office environment\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBepFhNa7YrqoayZ6Cu3wdL2s6CMnsXFa8kBM1K-fBg7CoEbcJjg5sodC9-SRQIDY2XfkmCqQYW2nBDyr3Ue5scMNjMsdvzhaOEZmgcBpiatRYvg55pPsnGMJ5q1OWnIocIWHSbjs0-YyUin2Pc78TgvzXkSbMDS-tQOdZmhCL1D64mabVK3QCGZGwIkYotwKuvGZOGUs_F2dzcx3YlCBf64yWIquQdaR2sSEkNj_pJx7iMBYMO-mwrBbaNNCT2_SkbmSVdxuppSqw\"/>\n</div>\n</div>\n</header>\n<!-- NavigationDrawer (Web) -->\n<aside class=\"hidden lg:flex flex-col p-4 fixed left-0 top-0 h-full z-[60] bg-slate-900 dark:bg-black h-full w-64 rounded-r-3xl shadow-2xl tonal-sculpting gap-2 Cubic-bezier(0.4, 0, 0.2, 1) transition-all\">\n<div class=\"p-6 mb-4\">\n<div class=\"flex items-center gap-3 mb-6\">\n<div class=\"w-10 h-10 rounded-full bg-sky-400 flex items-center justify-center text-slate-900 font-bold\">A</div>\n<div>\n<p class=\"font-['Space_Grotesk'] text-sm font-medium text-sky-400\">Adventurer</p>\n<p class=\"text-[10px] text-slate-400 uppercase tracking-widest\">Premium Member</p>\n</div>\n</div>\n</div>\n<nav class=\"flex flex-col gap-1\">\n<a class=\"text-slate-400 hover:text-slate-100 px-4 py-3 font-['Space_Grotesk'] text-sm font-medium hover:bg-slate-800 transition-colors flex items-center gap-3\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"home\">home</span> Home\n            </a>\n<a class=\"bg-sky-500/10 text-sky-400 rounded-full px-4 py-3 font-['Space_Grotesk'] text-sm font-medium transition-all flex items-center gap-3\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"explore\">explore</span> Trips\n            </a>\n<a class=\"text-slate-400 hover:text-slate-100 px-4 py-3 font-['Space_Grotesk'] text-sm font-medium hover:bg-slate-800 transition-colors flex items-center gap-3\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"edit_note\">edit_note</span> Journal\n            </a>\n<a class=\"text-slate-400 hover:text-slate-100 px-4 py-3 font-['Space_Grotesk'] text-sm font-medium hover:bg-slate-800 transition-colors flex items-center gap-3\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"settings\">settings</span> Settings\n            </a>\n</nav>\n</aside>\n<main class=\"pt-24 pb-32 px-6 lg:ml-64 max-w-7xl mx-auto\">\n<!-- Header Section -->\n<div class=\"flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12\">\n<div class=\"space-y-2\">\n<span class=\"text-primary font-label tracking-widest text-xs font-bold uppercase\">Collaboration Hub</span>\n<h2 class=\"text-5xl font-headline font-bold text-on-surface -ml-1\">Team Catalyst</h2>\n<p class=\"text-on-surface-variant max-w-lg leading-relaxed\">Manage your workspace collaborators, monitor pending invitations, and review access requests in a single unified gallery.</p>\n</div>\n<button class=\"primary-gradient text-white font-bold px-8 py-4 rounded-full aura-shadow hover:translate-y-[-1px] transition-all flex items-center gap-2 w-fit\">\n<span class=\"material-symbols-outlined\" data-icon=\"person_add\">person_add</span>\n                Invite User\n            </button>\n</div>\n<!-- Bento Layout -->\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8\">\n<!-- Active Members (Large Section) -->\n<section class=\"lg:col-span-8 space-y-6\">\n<div class=\"flex items-center justify-between px-2\">\n<h3 class=\"font-headline text-2xl font-bold flex items-center gap-2\">\n                        Active Members\n                        <span class=\"text-xs bg-surface-container-high px-2 py-1 rounded-full text-primary font-mono\">12</span>\n</h3>\n<button class=\"text-primary text-sm font-semibold hover:underline decoration-2 underline-offset-4\">Manage Roles</button>\n</div>\n<div class=\"bg-surface-container-low rounded-lg p-1 grid grid-cols-1 md:grid-cols-2 gap-4\">\n<!-- Member Card 1 -->\n<div class=\"bg-surface-container-lowest p-6 rounded-lg aura-shadow flex items-center gap-4 group\">\n<div class=\"relative\">\n<img alt=\"Sarah Chen\" class=\"w-14 h-14 rounded-full object-cover\" data-alt=\"close-up portrait of a woman with a bright smile in a professional studio setting with soft lighting\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuC1zzpvf3YCTK25PDY8uMbC8IA4k0I86mmUVGLa24xJzOTMVizbFAiqOjOZhg8guTtFEeG5nFFWgBvRR3HNnsdu1XZkyW02O_KtJkAyZInKm9CwcJ9KgL08I71K9VictJJY9Ib2YtFSd4MGyMZf36ToI8pvACkaaYEZdkZoUvEr_coGpfOo08xf7rexGkU7RgA-uM0qZDnePf_WWt-n3eI8cwqMW4AaSqaddOTP1SnqyiZ_rZtPBdC4kpIwjVDia9sYPGSJYJNhiA4\"/>\n<span class=\"absolute bottom-0 right-0 w-4 h-4 bg-secondary border-2 border-white rounded-full\"></span>\n</div>\n<div class=\"flex-grow\">\n<h4 class=\"font-bold text-on-surface\">Sarah Chen</h4>\n<p class=\"text-xs text-on-surface-variant font-mono\">Lead Curator / Editor</p>\n</div>\n<button class=\"opacity-0 group-hover:opacity-100 transition-opacity p-2 hover:bg-surface-container rounded-full text-outline\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n<!-- Member Card 2 -->\n<div class=\"bg-surface-container-lowest p-6 rounded-lg aura-shadow flex items-center gap-4 group\">\n<div class=\"relative\">\n<img alt=\"Marcus Wright\" class=\"w-14 h-14 rounded-full object-cover\" data-alt=\"professional headshot of a middle-aged man with short beard and glasses looking confidently at the camera\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDVSMI7UV8UZnKw8RAxegzB59-zTspCmDem0uzsb-96FNw9648wZBtXvr3-5NCPykRUtYE_3rEMOA7l4BEHyciwkxo9i_wCVEEPM28w18Ugv0dCoUAEYnc9oeAD3D6T-H0R7rlmmJ9uOEb9mI2lFyA1XziIngvrapYcZHzw5qKCTASLxzRFkQe6apiyCsKhL1qOtZEDS9Bb3VSnnp9Nm_NaZhvqMudC7hT-FsIacc5TBgWQ3qeRB346Pm3O1A5oaVTxW6nl77MQJMU\"/>\n<span class=\"absolute bottom-0 right-0 w-4 h-4 bg-secondary border-2 border-white rounded-full\"></span>\n</div>\n<div class=\"flex-grow\">\n<h4 class=\"font-bold text-on-surface\">Marcus Wright</h4>\n<p class=\"text-xs text-on-surface-variant font-mono\">Design Systems / Editor</p>\n</div>\n<button class=\"opacity-0 group-hover:opacity-100 transition-opacity p-2 hover:bg-surface-container rounded-full text-outline\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n<!-- Member Card 3 -->\n<div class=\"bg-surface-container-lowest p-6 rounded-lg aura-shadow flex items-center gap-4 group\">\n<div class=\"relative\">\n<img alt=\"Elena Rodriguez\" class=\"w-14 h-14 rounded-full object-cover\" data-alt=\"close-up portrait of a professional woman with dark hair in a sleek blazer, minimalist corporate background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCIijSa1EezfzXxE7l4z1qHxafGKrDx56uwakTERQ2Spt6yEoTF4MxBx1Ez4aeEzz9NwgJTuXBWmerL83K2QSM-m22XYadtTldhlml2HPAyL1tK-Qu-FJY0_Qb44qbKHGRBJE3K522mXQgEfMrhHrdF95Nh_-EdV0eE3RBlgcbUfhb-I67gUPYTOqG63yOLzVcvaAxCdW2Vuy3SFrrKB6TJNdLhUNWfEwHK_mFPmapgKsdDRnuJMUM3l3wTLXnuQQW4O03-e0495aE\"/>\n<span class=\"absolute bottom-0 right-0 w-4 h-4 bg-outline-variant border-2 border-white rounded-full\"></span>\n</div>\n<div class=\"flex-grow\">\n<h4 class=\"font-bold text-on-surface\">Elena Rodriguez</h4>\n<p class=\"text-xs text-on-surface-variant font-mono\">UX Researcher / Viewer</p>\n</div>\n<button class=\"opacity-0 group-hover:opacity-100 transition-opacity p-2 hover:bg-surface-container rounded-full text-outline\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n<!-- Member Card 4 -->\n<div class=\"bg-surface-container-lowest p-6 rounded-lg aura-shadow flex items-center gap-4 group\">\n<div class=\"relative\">\n<div class=\"w-14 h-14 rounded-full bg-surface-container flex items-center justify-center text-primary font-bold font-headline text-lg italic\">JW</div>\n<span class=\"absolute bottom-0 right-0 w-4 h-4 bg-secondary border-2 border-white rounded-full\"></span>\n</div>\n<div class=\"flex-grow\">\n<h4 class=\"font-bold text-on-surface\">James Wu</h4>\n<p class=\"text-xs text-on-surface-variant font-mono\">Brand Architect / Editor</p>\n</div>\n<button class=\"opacity-0 group-hover:opacity-100 transition-opacity p-2 hover:bg-surface-container rounded-full text-outline\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n</div>\n</section>\n<!-- Access Requests (Sidebar Section) -->\n<section class=\"lg:col-span-4 space-y-6\">\n<div class=\"flex items-center justify-between px-2\">\n<h3 class=\"font-headline text-2xl font-bold\">Access Requests</h3>\n<span class=\"text-xs bg-error-container px-2 py-1 rounded-full text-error font-mono font-bold\">New</span>\n</div>\n<div class=\"space-y-4\">\n<!-- Request Card -->\n<div class=\"glass-panel p-6 rounded-lg aura-shadow border-l-4 border-primary\">\n<div class=\"flex items-start gap-4 mb-4\">\n<div class=\"w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary font-bold\">LO</div>\n<div>\n<h4 class=\"font-bold text-on-surface\">Liam O'Conner</h4>\n<p class=\"text-xs text-on-surface-variant\">Requesting <span class=\"text-primary font-semibold\">Editor</span> access</p>\n<p class=\"text-[10px] text-outline mt-1 italic\">\"Need access to update the July roadmap.\"</p>\n</div>\n</div>\n<div class=\"flex gap-2\">\n<button class=\"flex-1 bg-primary text-white text-sm font-bold py-2 rounded-full hover:opacity-90 transition-opacity\">Approve</button>\n<button class=\"flex-1 border border-outline-variant text-on-surface-variant text-sm font-bold py-2 rounded-full hover:bg-surface-container transition-colors\">Reject</button>\n</div>\n</div>\n<!-- Request Card 2 -->\n<div class=\"glass-panel p-6 rounded-lg aura-shadow\">\n<div class=\"flex items-start gap-4 mb-4\">\n<div class=\"w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary font-bold\">SN</div>\n<div>\n<h4 class=\"font-bold text-on-surface\">Sofia Novak</h4>\n<p class=\"text-xs text-on-surface-variant\">Requesting <span class=\"text-primary font-semibold\">Viewer</span> access</p>\n</div>\n</div>\n<div class=\"flex gap-2\">\n<button class=\"flex-1 bg-primary text-white text-sm font-bold py-2 rounded-full hover:opacity-90 transition-opacity\">Approve</button>\n<button class=\"flex-1 border border-outline-variant text-on-surface-variant text-sm font-bold py-2 rounded-full hover:bg-surface-container transition-colors\">Reject</button>\n</div>\n</div>\n</div>\n</section>\n<!-- Pending Invitations (Wide Section) -->\n<section class=\"lg:col-span-12 space-y-6\">\n<h3 class=\"font-headline text-2xl font-bold px-2\">Pending Invitations</h3>\n<div class=\"bg-surface-container rounded-lg p-6 overflow-x-auto\">\n<table class=\"w-full border-separate border-spacing-y-2\">\n<thead>\n<tr class=\"text-left text-xs font-mono text-outline uppercase tracking-widest\">\n<th class=\"px-4 pb-2\">User / Email</th>\n<th class=\"px-4 pb-2\">Intended Role</th>\n<th class=\"px-4 pb-2\">Status</th>\n<th class=\"px-4 pb-2 text-right\">Actions</th>\n</tr>\n</thead>\n<tbody>\n<tr class=\"bg-surface-container-lowest rounded-lg group\">\n<td class=\"px-4 py-4 rounded-l-lg\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-8 h-8 rounded-full bg-primary-container/20 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-primary scale-75\" data-icon=\"alternate_email\">alternate_email</span>\n</div>\n<div>\n<p class=\"font-bold text-sm\">david.vance@studio.com</p>\n<p class=\"text-[10px] text-outline\">Sent 2 days ago</p>\n</div>\n</div>\n</td>\n<td class=\"px-4 py-4\">\n<span class=\"text-xs font-mono bg-surface-container-high px-2 py-1 rounded\">EDITOR</span>\n</td>\n<td class=\"px-4 py-4\">\n<div class=\"flex items-center gap-2\">\n<span class=\"w-2 h-2 rounded-full bg-tertiary-container\"></span>\n<span class=\"text-xs font-semibold text-tertiary\">Waiting for Response</span>\n</div>\n</td>\n<td class=\"px-4 py-4 rounded-r-lg text-right\">\n<button class=\"text-error text-xs font-bold uppercase tracking-widest hover:underline underline-offset-4\">Cancel</button>\n</td>\n</tr>\n<tr class=\"bg-surface-container-lowest rounded-lg group\">\n<td class=\"px-4 py-4 rounded-l-lg\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-8 h-8 rounded-full bg-primary-container/20 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-primary scale-75\" data-icon=\"alternate_email\">alternate_email</span>\n</div>\n<div>\n<p class=\"font-bold text-sm\">tina.f@creative-hub.net</p>\n<p class=\"text-[10px] text-outline\">Sent 5 hours ago</p>\n</div>\n</div>\n</td>\n<td class=\"px-4 py-4\">\n<span class=\"text-xs font-mono bg-surface-container-high px-2 py-1 rounded\">VIEWER</span>\n</td>\n<td class=\"px-4 py-4\">\n<div class=\"flex items-center gap-2\">\n<span class=\"w-2 h-2 rounded-full bg-tertiary-container\"></span>\n<span class=\"text-xs font-semibold text-tertiary\">Waiting for Response</span>\n</div>\n</td>\n<td class=\"px-4 py-4 rounded-r-lg text-right\">\n<button class=\"text-error text-xs font-bold uppercase tracking-widest hover:underline underline-offset-4\">Cancel</button>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</section>\n</div>\n</main>\n<!-- BottomNavBar (Mobile Only) -->\n<nav class=\"md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 dark:bg-slate-950/80 backdrop-blur-lg rounded-t-[2.5rem] shadow-[0_-10px_40px_-12px_rgba(0,0,0,0.1)]\">\n<button class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 px-5 py-2 hover:text-sky-400 transition-all Active: translateY(-2px) transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"home\">home</span>\n<span class=\"font-['Inter'] text-[10px] font-semibold uppercase tracking-widest mt-1\">Home</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-sky-500 dark:text-sky-400 bg-sky-50 dark:bg-sky-900/20 rounded-full px-5 py-2 hover:text-sky-400 transition-all Active: translateY(-2px) transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"explore\">explore</span>\n<span class=\"font-['Inter'] text-[10px] font-semibold uppercase tracking-widest mt-1\">Trips</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 px-5 py-2 hover:text-sky-400 transition-all Active: translateY(-2px) transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"edit_note\">edit_note</span>\n<span class=\"font-['Inter'] text-[10px] font-semibold uppercase tracking-widest mt-1\">Journal</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 px-5 py-2 hover:text-sky-400 transition-all Active: translateY(-2px) transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"settings\">settings</span>\n<span class=\"font-['Inter'] text-[10px] font-semibold uppercase tracking-widest mt-1\">Settings</span>\n</button>\n</nav>\n</body></html>"}
