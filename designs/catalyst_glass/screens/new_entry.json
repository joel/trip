{"screenId":"613c93dcdc6e4f3ea2eb631d18217e3e","projectId":"3314239195447065678","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Trip Journal - New Entry</title>\n<!-- Tailwind CSS -->\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<!-- Google Fonts -->\n<link href=\"https://fonts.googleapis.com\" rel=\"preconnect\"/>\n<link crossorigin=\"\" href=\"https://fonts.gstatic.com\" rel=\"preconnect\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=JetBrains+Mono&amp;family=Space+Grotesk:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<!-- Material Symbols -->\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"on-primary\": \"#ffffff\",\n              \"surface-dim\": \"#d2d9f4\",\n              \"tertiary-fixed-dim\": \"#ffb960\",\n              \"outline-variant\": \"#bdc8d1\",\n              \"on-tertiary-fixed-variant\": \"#653e00\",\n              \"primary-fixed-dim\": \"#7bd0ff\",\n              \"surface\": \"#faf8ff\",\n              \"tertiary-container\": \"#f1a02b\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"tertiary-fixed\": \"#ffddb8\",\n              \"inverse-on-surface\": \"#eef0ff\",\n              \"secondary-fixed\": \"#68fcbf\",\n              \"surface-container-highest\": \"#dae2fd\",\n              \"inverse-surface\": \"#283044\",\n              \"on-surface-variant\": \"#3e484f\",\n              \"on-surface\": \"#131b2e\",\n              \"surface-bright\": \"#faf8ff\",\n              \"error\": \"#ba1a1a\",\n              \"tertiary\": \"#855300\",\n              \"on-tertiary-fixed\": \"#2a1700\",\n              \"surface-tint\": \"#00668a\",\n              \"secondary-container\": \"#64f9bc\",\n              \"primary\": \"#00668a\",\n              \"secondary\": \"#006c4b\",\n              \"primary-fixed\": \"#c4e7ff\",\n              \"on-primary-fixed\": \"#001e2c\",\n              \"on-secondary\": \"#ffffff\",\n              \"on-tertiary-container\": \"#613b00\",\n              \"on-primary-container\": \"#004965\",\n              \"secondary-fixed-dim\": \"#45dfa4\",\n              \"outline\": \"#6e7980\",\n              \"surface-container-low\": \"#f2f3ff\",\n              \"on-tertiary\": \"#ffffff\",\n              \"on-background\": \"#131b2e\",\n              \"surface-container\": \"#eaedff\",\n              \"on-error\": \"#ffffff\",\n              \"on-secondary-fixed-variant\": \"#005137\",\n              \"background\": \"#faf8ff\",\n              \"on-primary-fixed-variant\": \"#004c69\",\n              \"error-container\": \"#ffdad6\",\n              \"inverse-primary\": \"#7bd0ff\",\n              \"surface-container-high\": \"#e2e7ff\",\n              \"surface-variant\": \"#dae2fd\",\n              \"on-secondary-container\": \"#00714e\",\n              \"primary-container\": \"#38bdf8\",\n              \"on-secondary-fixed\": \"#002114\",\n              \"on-error-container\": \"#93000a\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Inter\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"1rem\", \"lg\": \"2rem\", \"xl\": \"3rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n            display: inline-block;\n            line-height: 1;\n            text-transform: none;\n            letter-spacing: normal;\n            word-wrap: normal;\n            white-space: nowrap;\n            direction: ltr;\n        }\n        \n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #faf8ff;\n        }\n\n        .font-headline { font-family: 'Space Grotesk', sans-serif; }\n        \n        .glass-panel {\n            background: rgba(255, 255, 255, 0.7);\n            backdrop-filter: blur(20px) saturate(180%);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n\n        .aura-bg {\n            position: fixed;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            z-index: -1;\n            overflow: hidden;\n        }\n\n        .aura-blob {\n            position: absolute;\n            border-radius: 50%;\n            filter: blur(80px);\n            opacity: 0.15;\n        }\n\n        .input-focus-ring:focus {\n            outline: none;\n            box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.1);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"text-on-surface antialiased overflow-x-hidden\">\n<!-- Background Auras -->\n<div class=\"aura-bg\">\n<div class=\"aura-blob bg-primary-container w-[500px] h-[500px] -top-24 -right-24\"></div>\n<div class=\"aura-blob bg-secondary-container w-[400px] h-[400px] bottom-0 -left-24\"></div>\n</div>\n<!-- NavigationDrawer (Shared Component) -->\n<nav class=\"fixed inset-y-0 left-0 z-50 flex flex-col bg-[#0b1220] dark:bg-[#0b1220] rounded-r-[2rem] h-full w-72 shadow-[0_20px_40px_-12px_rgba(11,18,32,0.5)] font-['Space_Grotesk'] antialiased tracking-tight hidden md:flex\">\n<div class=\"p-8 flex flex-col h-full\">\n<!-- Profile Header -->\n<div class=\"flex items-start gap-4 mb-12\">\n<div class=\"w-12 h-12 rounded-2xl overflow-hidden ring-2 ring-sky-500/20\">\n<img alt=\"User Profile\" class=\"w-full h-full object-cover\" data-alt=\"Portrait of a creative professional with glasses and a friendly expression in a minimalist vector style\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAf2ZBot6g_p5Ymtp1YypYrXOJSzuXM2z2nXKf4sobPGtFrtPdZ7NeDbRU6KV91tYEWI9t38rbXHPh1s_-P0Ow9yPLHdYgEW5sK1704Z6yvcBx7BA86P9wFhhvgNzkNYzr2qwzgrv9Q0F4IIssdOoSAo1jN8moIuv_h7rW5U1U_HCLSMfebZWyjyL7E4sKyvk9RyvebcMxO_Ro8qlGryEzpsHsXS5eVrmS1fLXbsz20VJX0PP-KnPP00rUCWWYmv16iUmgM6ZbUREg\"/>\n</div>\n<div>\n<h3 class=\"text-white font-bold tracking-tight\">Alex Rivers</h3>\n<p class=\"text-slate-400 text-xs\">Global Explorer</p>\n<span class=\"text-sky-400 text-[10px] font-mono mt-1 block\">128 Entries</span>\n</div>\n</div>\n<!-- Navigation Items -->\n<div class=\"flex flex-col gap-2 flex-grow\">\n<a class=\"bg-sky-500/10 text-sky-400 rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 active:scale-[0.98]\" href=\"#\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">edit_note</span>\n<span class=\"font-medium\">Journal</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\">map</span>\n<span class=\"font-medium\">Map</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\">photo_library</span>\n<span class=\"font-medium\">Memories</span>\n</a>\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\">explore</span>\n<span class=\"font-medium\">Discover</span>\n</a>\n</div>\n<!-- Footer Navigation -->\n<div class=\"mt-auto\">\n<a class=\"text-slate-400 hover:text-white rounded-2xl mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/5\" href=\"#\">\n<span class=\"material-symbols-outlined\">settings</span>\n<span class=\"font-medium\">Settings</span>\n</a>\n</div>\n</div>\n</nav>\n<!-- Main Content Area -->\n<main class=\"md:ml-72 min-h-screen pb-24 md:pb-12\">\n<!-- TopAppBar (Shared Component Overlay Logic) -->\n<header class=\"fixed top-0 right-0 left-0 md:left-72 z-40 flex justify-between items-center px-8 h-20 bg-white/70 backdrop-blur-xl transition-all duration-200\">\n<div class=\"flex items-center gap-4\">\n<button class=\"md:hidden text-on-surface p-2 rounded-xl hover:bg-surface-container-low transition-colors\">\n<span class=\"material-symbols-outlined\">menu</span>\n</button>\n<h1 class=\"font-headline font-bold text-2xl tracking-tight text-on-surface\">New Entry</h1>\n</div>\n<div class=\"flex items-center gap-4\">\n<button class=\"flex items-center gap-2 px-6 py-2.5 bg-gradient-to-br from-primary to-primary-container text-white rounded-full font-headline font-semibold text-sm shadow-[0_10px_20px_-5px_rgba(0,102,138,0.3)] hover:translate-y-[-1px] transition-all active:scale-95\">\n<span class=\"material-symbols-outlined text-[18px]\">save</span>\n                    Save Entry\n                </button>\n<div class=\"w-10 h-10 rounded-full overflow-hidden border-2 border-surface-container-highest md:block hidden\">\n<img alt=\"User Avatar\" class=\"w-full h-full object-cover\" data-alt=\"Stylized avatar of a user with light skin and short hair\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuC8z-3iWs0UxuyzAzsRz7XJ5uGWNrgUQDsLDqA7Fbob95vfLjGRN_cfbugE9QQy8uSXoDwABnNfKICbTlVCzU02NnxONRkRa-Xh4UXEQxR7hQjLS5Z4SuXkYkr4lJnt6j1rvmAM260GpayeiSFott9SXxjNKxsOtMNXHpRnIEhJ5CYXGUdnneGI6og3mIvA3F_zYTAGY67TYYyaULCQGwjG6jOp5jQzTNegiA0fHtNc_3KHx_dcWWmXRHqwGgBwsVo79Ov4VEVJ5AA\"/>\n</div>\n</div>\n</header>\n<!-- Focused Writing Canvas -->\n<div class=\"max-w-5xl mx-auto px-6 pt-32\">\n<div class=\"flex flex-col gap-10\">\n<!-- Journal Entry Form -->\n<form class=\"space-y-12\">\n<!-- Title & Date -->\n<div class=\"space-y-6\">\n<input class=\"w-full bg-transparent border-none text-4xl md:text-6xl font-headline font-bold text-on-surface placeholder:text-surface-container-highest focus:ring-0 px-0 selection:bg-primary-fixed\" placeholder=\"Title of your journey...\" type=\"text\"/>\n<div class=\"flex items-center gap-6\">\n<div class=\"flex items-center gap-2 px-4 py-2 bg-surface-container-low rounded-2xl text-on-surface-variant border border-outline-variant/10\">\n<span class=\"material-symbols-outlined text-[20px]\">calendar_today</span>\n<input class=\"bg-transparent border-none p-0 text-sm font-medium focus:ring-0 w-36\" type=\"text\" value=\"October 24, 2023\"/>\n</div>\n<div class=\"flex items-center gap-2 px-4 py-2 bg-surface-container-low rounded-2xl text-on-surface-variant border border-outline-variant/10\">\n<span class=\"material-symbols-outlined text-[20px]\">location_on</span>\n<input class=\"bg-transparent border-none p-0 text-sm font-medium focus:ring-0 w-32\" placeholder=\"Add location\" type=\"text\"/>\n</div>\n</div>\n</div>\n<!-- Image Uploader Glass Zone -->\n<div class=\"group relative\">\n<div class=\"w-full h-72 rounded-[2rem] glass-panel border-dashed border-2 border-outline-variant/30 flex flex-col items-center justify-center gap-4 cursor-pointer hover:border-primary/50 transition-all duration-500 overflow-hidden relative\">\n<!-- Background preview hint -->\n<div class=\"absolute inset-0 opacity-10 grayscale group-hover:scale-110 transition-transform duration-700\">\n<img class=\"w-full h-full object-cover\" data-alt=\"Serene lake landscape with mountains in the background at twilight with soft purple and blue hues\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuD7inpkNM7nwVPLEVlFcyCSMNvaRYCp4rlt58N222hKiiBB46NPf9uc52IbsNdvmzR0oOCR7MfgujW8fYmk7u_1ioemfSxvbJQTfKz7vz3M4EkUz70Jx0rD9wDEezGPfeptaQ5F3m8fo_MtGUQTetbNR-L6VnHsH4RIrfH9hwuRdcsNa2YuvqZt6nkt_oQG6r6qjUFVT4IW6EEKKh_j5UGOyqjR44G77k-Bw97zBc7Af8v13ZQrdOAsl-Jj8ReUnT-rYnp2UmrmxZs\"/>\n</div>\n<div class=\"relative z-10 flex flex-col items-center\">\n<div class=\"w-16 h-16 bg-white/80 rounded-2xl flex items-center justify-center mb-2 shadow-sm text-primary\">\n<span class=\"material-symbols-outlined text-[32px]\">add_photo_alternate</span>\n</div>\n<p class=\"font-headline font-bold text-on-surface\">Add Cover Photo</p>\n<p class=\"text-on-surface-variant text-sm\">Drag and drop or click to browse</p>\n</div>\n</div>\n</div>\n<!-- Editor Tools (Floating Glass) -->\n<div class=\"sticky top-24 z-30 flex justify-center\">\n<div class=\"glass-panel px-4 py-2 rounded-2xl flex items-center gap-1 shadow-xl shadow-surface-dim/20\">\n<button class=\"p-2 hover:bg-surface-container-highest rounded-xl text-on-surface-variant transition-colors\" type=\"button\">\n<span class=\"material-symbols-outlined\">format_bold</span>\n</button>\n<button class=\"p-2 hover:bg-surface-container-highest rounded-xl text-on-surface-variant transition-colors\" type=\"button\">\n<span class=\"material-symbols-outlined\">format_italic</span>\n</button>\n<button class=\"p-2 hover:bg-surface-container-highest rounded-xl text-on-surface-variant transition-colors\" type=\"button\">\n<span class=\"material-symbols-outlined\">format_quote</span>\n</button>\n<div class=\"w-px h-6 bg-outline-variant/30 mx-2\"></div>\n<button class=\"p-2 hover:bg-surface-container-highest rounded-xl text-on-surface-variant transition-colors\" type=\"button\">\n<span class=\"material-symbols-outlined\">format_list_bulleted</span>\n</button>\n<button class=\"p-2 hover:bg-surface-container-highest rounded-xl text-on-surface-variant transition-colors\" type=\"button\">\n<span class=\"material-symbols-outlined\">link</span>\n</button>\n<button class=\"p-2 hover:bg-surface-container-highest rounded-xl text-on-surface-variant transition-colors\" type=\"button\">\n<span class=\"material-symbols-outlined\">sentiment_satisfied</span>\n</button>\n</div>\n</div>\n<!-- Body Text Area -->\n<div class=\"min-h-[500px]\">\n<textarea class=\"w-full min-h-[500px] bg-transparent border-none text-xl leading-relaxed text-on-surface placeholder:text-surface-container-highest focus:ring-0 px-0 resize-none font-body\" placeholder=\"Start writing your story here...\"></textarea>\n</div>\n</form>\n<!-- Metadata / Tags Sidebar Logic as Inline Bento -->\n<div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 pt-12 border-t border-outline-variant/10\">\n<div class=\"bg-surface-container-low p-6 rounded-lg flex flex-col gap-4\">\n<div class=\"flex items-center gap-2 text-primary\">\n<span class=\"material-symbols-outlined text-[20px]\">label</span>\n<span class=\"font-headline font-bold uppercase text-xs tracking-widest\">Tags</span>\n</div>\n<div class=\"flex flex-wrap gap-2\">\n<span class=\"px-3 py-1 bg-white rounded-full text-sm font-medium text-on-surface-variant\">Adventure</span>\n<span class=\"px-3 py-1 bg-white rounded-full text-sm font-medium text-on-surface-variant\">2023</span>\n<button class=\"px-3 py-1 border border-dashed border-outline-variant rounded-full text-sm font-medium text-on-surface-variant hover:bg-white transition-colors\">+ Add</button>\n</div>\n</div>\n<div class=\"bg-surface-container-low p-6 rounded-lg flex flex-col gap-4\">\n<div class=\"flex items-center gap-2 text-primary\">\n<span class=\"material-symbols-outlined text-[20px]\">visibility</span>\n<span class=\"font-headline font-bold uppercase text-xs tracking-widest\">Visibility</span>\n</div>\n<select class=\"bg-white border-none rounded-xl text-sm font-medium focus:ring-primary/20\">\n<option>Private (Only me)</option>\n<option>Friends only</option>\n<option>Public</option>\n</select>\n</div>\n<div class=\"bg-surface-container-low p-6 rounded-lg flex flex-col gap-4\">\n<div class=\"flex items-center gap-2 text-primary\">\n<span class=\"material-symbols-outlined text-[20px]\">mood</span>\n<span class=\"font-headline font-bold uppercase text-xs tracking-widest\">Mood Check</span>\n</div>\n<div class=\"flex justify-between items-center text-2xl px-2\">\n<button class=\"grayscale hover:grayscale-0 transition-all transform hover:scale-125\">😌</button>\n<button class=\"grayscale hover:grayscale-0 transition-all transform hover:scale-125\">🤩</button>\n<button class=\"grayscale hover:grayscale-0 transition-all transform hover:scale-125\">🤯</button>\n<button class=\"grayscale hover:grayscale-0 transition-all transform hover:scale-125\">🌊</button>\n</div>\n</div>\n</div>\n</div>\n</div>\n</main>\n<!-- BottomNavBar (Mobile Only) -->\n<nav class=\"md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 backdrop-blur-2xl border-t border-white/20 shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.1)] rounded-t-[2.5rem]\">\n<a class=\"flex flex-col items-center justify-center text-slate-400 hover:text-sky-400 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">home</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest\">Home</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-sky-500 font-bold scale-110 translate-y-[-2px]\" href=\"#\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">draw</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest\">Drafts</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-slate-400 hover:text-sky-400 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">bookmark</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest\">Saved</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-slate-400 hover:text-sky-400 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">person</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] font-medium uppercase tracking-widest\">Profile</span>\n</a>\n</nav>\n</body></html>"}
