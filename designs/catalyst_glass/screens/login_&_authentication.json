{"screenId":"308d8a95e59541abae8f49019bec6f9e","projectId":"3314239195447065678","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Catalyst - Login</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"tertiary\": \"#855300\",\n              \"inverse-on-surface\": \"#eef0ff\",\n              \"surface-container-low\": \"#f2f3ff\",\n              \"surface\": \"#faf8ff\",\n              \"secondary-fixed-dim\": \"#45dfa4\",\n              \"on-primary-container\": \"#004965\",\n              \"on-tertiary-fixed\": \"#2a1700\",\n              \"on-error\": \"#ffffff\",\n              \"primary-fixed\": \"#c4e7ff\",\n              \"outline\": \"#6e7980\",\n              \"secondary\": \"#006c4b\",\n              \"inverse-primary\": \"#7bd0ff\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"surface-container-high\": \"#e2e7ff\",\n              \"primary\": \"#00668a\",\n              \"surface-container\": \"#eaedff\",\n              \"background\": \"#faf8ff\",\n              \"surface-dim\": \"#d2d9f4\",\n              \"on-surface-variant\": \"#3e484f\",\n              \"secondary-fixed\": \"#68fcbf\",\n              \"on-secondary-fixed-variant\": \"#005137\",\n              \"inverse-surface\": \"#283044\",\n              \"error-container\": \"#ffdad6\",\n              \"on-primary-fixed-variant\": \"#004c69\",\n              \"primary-container\": \"#38bdf8\",\n              \"on-surface\": \"#131b2e\",\n              \"outline-variant\": \"#bdc8d1\",\n              \"on-tertiary\": \"#ffffff\",\n              \"surface-container-highest\": \"#dae2fd\",\n              \"on-background\": \"#131b2e\",\n              \"secondary-container\": \"#64f9bc\",\n              \"on-secondary-fixed\": \"#002114\",\n              \"on-secondary-container\": \"#00714e\",\n              \"surface-variant\": \"#dae2fd\",\n              \"tertiary-fixed\": \"#ffddb8\",\n              \"on-secondary\": \"#ffffff\",\n              \"tertiary-container\": \"#f1a02b\",\n              \"on-primary\": \"#ffffff\",\n              \"tertiary-fixed-dim\": \"#ffb960\",\n              \"surface-bright\": \"#faf8ff\",\n              \"on-tertiary-fixed-variant\": \"#653e00\",\n              \"error\": \"#ba1a1a\",\n              \"surface-tint\": \"#00668a\",\n              \"on-error-container\": \"#93000a\",\n              \"primary-fixed-dim\": \"#7bd0ff\",\n              \"on-primary-fixed\": \"#001e2c\",\n              \"on-tertiary-container\": \"#613b00\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Inter\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"1rem\", \"lg\": \"2rem\", \"xl\": \"3rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .aura-gradient {\n            background: linear-gradient(135deg, #00668a, #38bdf8);\n        }\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.7);\n            backdrop-filter: blur(20px) saturate(180%);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n        .tonal-sculpting {\n            box-shadow: 0 20px 40px -12px rgba(19, 27, 46, 0.08);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-surface font-body min-h-screen flex items-center justify-center p-6 relative overflow-hidden\">\n<!-- Decorative Background Elements -->\n<div class=\"absolute top-[-10%] left-[-10%] w-[40%] h-[40%] aura-gradient opacity-10 rounded-full blur-[120px]\"></div>\n<div class=\"absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-secondary-container opacity-10 rounded-full blur-[120px]\"></div>\n<!-- Main Content Canvas -->\n<main class=\"w-full max-w-md z-10\">\n<!-- Brand Identity Section -->\n<div class=\"text-center mb-10\">\n<div class=\"inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary mb-4 shadow-lg\">\n<span class=\"material-symbols-outlined text-white text-3xl\">auto_awesome</span>\n</div>\n<h1 class=\"font-headline text-4xl font-bold tracking-tight text-on-surface\">Catalyst</h1>\n<p class=\"text-on-surface-variant font-medium mt-2\">Document your journey, frame by frame.</p>\n</div>\n<!-- Login Card -->\n<div class=\"glass-panel rounded-lg p-8 tonal-sculpting\">\n<div class=\"flex flex-col gap-6\">\n<!-- Header -->\n<div class=\"space-y-1\">\n<h2 class=\"text-2xl font-headline font-semibold text-on-surface\">Welcome back</h2>\n<p class=\"text-sm text-on-surface-variant\">Sign in to your adventurer profile</p>\n</div>\n<!-- Form Fields -->\n<form class=\"space-y-4\" onsubmit=\"return false;\">\n<div class=\"space-y-2\">\n<label class=\"text-sm font-label font-medium text-on-surface-variant ml-1\">Email Address</label>\n<div class=\"relative\">\n<span class=\"material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-xl\">mail</span>\n<input class=\"w-full pl-12 pr-4 py-3.5 bg-surface-container-highest border-none rounded-md focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline-variant\" placeholder=\"explorer@catalyst.com\" type=\"email\"/>\n</div>\n</div>\n<div class=\"space-y-2\">\n<div class=\"flex justify-between items-center ml-1\">\n<label class=\"text-sm font-label font-medium text-on-surface-variant\">Password</label>\n<a class=\"text-xs font-label text-primary hover:opacity-80 transition-opacity\" href=\"#\">Forgot Password?</a>\n</div>\n<div class=\"relative\">\n<span class=\"material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-xl\">lock</span>\n<input class=\"w-full pl-12 pr-12 py-3.5 bg-surface-container-highest border-none rounded-md focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all\" placeholder=\"••••••••\" type=\"password\"/>\n<button class=\"absolute right-4 top-1/2 -translate-y-1/2 text-outline hover:text-on-surface transition-colors\" type=\"button\">\n<span class=\"material-symbols-outlined text-xl\">visibility</span>\n</button>\n</div>\n</div>\n<div class=\"pt-2\">\n<button class=\"w-full aura-gradient text-white font-label font-bold py-4 rounded-full shadow-lg hover:translate-y-[-1px] active:scale-95 transition-all\">\n                            Login\n                        </button>\n</div>\n</form>\n<!-- Divider -->\n<div class=\"relative flex items-center py-2\">\n<div class=\"flex-grow border-t border-outline-variant opacity-30\"></div>\n<span class=\"flex-shrink mx-4 text-xs font-label text-outline uppercase tracking-widest\">or continue with</span>\n<div class=\"flex-grow border-t border-outline-variant opacity-30\"></div>\n</div>\n<!-- Passkey Authentication -->\n<button class=\"w-full flex items-center justify-center gap-3 bg-surface-container-low text-on-surface border border-outline-variant/20 font-label font-semibold py-4 rounded-full hover:bg-surface-container-high active:scale-95 transition-all\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">passkey</span>\n                    Login with Passkey\n                </button>\n</div>\n</div>\n<!-- Footer Actions -->\n<div class=\"mt-8 text-center space-y-4\">\n<p class=\"text-on-surface-variant font-medium\">\n                New to Catalyst? \n                <a class=\"text-primary font-bold hover:underline decoration-2 underline-offset-4 ml-1\" href=\"#\">Create Account</a>\n</p>\n<div class=\"flex justify-center gap-6 mt-4\">\n<a class=\"text-xs text-outline font-label uppercase tracking-widest hover:text-primary transition-colors\" href=\"#\">Terms</a>\n<a class=\"text-xs text-outline font-label uppercase tracking-widest hover:text-primary transition-colors\" href=\"#\">Privacy</a>\n<a class=\"text-xs text-outline font-label uppercase tracking-widest hover:text-primary transition-colors\" href=\"#\">Support</a>\n</div>\n</div>\n</main>\n<!-- Visual Anchor: Trip Preview Snippet -->\n<div class=\"hidden lg:block absolute right-12 bottom-12 w-80 glass-panel rounded-lg p-4 tonal-sculpting -rotate-3 overflow-hidden\">\n<div class=\"h-40 w-full rounded-md mb-4 overflow-hidden\">\n<img alt=\"Scenic valley\" class=\"w-full h-full object-cover\" data-alt=\"cinematic landscape of a mountain valley with a winding river at sunset with golden orange light and purple shadows\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAXz9n6FsMPAxXoU45_a9xNdhcfn0BW6j7bjGGA8nW6gy0vgSHDdzWQNdV5BZL8wJtxJg6Bo985RdL_E4mZPu9VtGOhcu5a9H6MiJYdx072s-CVWON6SPNicgi2Pc5eTTVWkW10_IIdLBtm901WF3xNWULY8W8JUFUndoCK_e1z3S_zPINv0Fv0TbtZ2pvfg9d7DcmqfhH14gaRbf7Y6xz24JhM0TgDTh4rYFbU0EwJlXwS7UjQERAonjjKyipwzjEpmUhCOFaJlQ8\"/>\n</div>\n<div class=\"space-y-2\">\n<div class=\"flex justify-between items-center\">\n<span class=\"text-xs font-mono text-primary font-bold\">#TRIP-2024</span>\n<span class=\"text-[10px] font-label bg-secondary-container/30 text-on-secondary-container px-2 py-0.5 rounded-full\">ACTIVE</span>\n</div>\n<h3 class=\"font-headline font-bold text-on-surface\">Alpine Discovery</h3>\n<p class=\"text-xs text-on-surface-variant line-clamp-2\">The air is thinner up here, but the view of the valley floor makes every step worth it...</p>\n</div>\n</div>\n</body></html>"}
