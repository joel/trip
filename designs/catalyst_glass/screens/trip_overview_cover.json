 .hero-gradient {\n            background: linear-gradient(to bottom, rgba(30, 27, 25, 0.2), rgba(30, 27, 25, 0.6));\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-surface font-body selection:bg-primary-fixed selection:text-on-primary-fixed\">\n<!-- Top Navigation Anchor -->\n<header class=\"fixed top-0 w-full z-50 flex items-center justify-between px-6 py-4 w-full bg-white/80 dark:bg-stone-900/80 backdrop-blur-xl no-line tonal-shift bg-stone-50/50 dark:bg-stone-950/50\">\n<div class=\"flex items-center gap-4\">\n<button class=\"w-10 h-10 flex items-center justify-center rounded-full hover:bg-stone-100/50 transition-colors active:scale-95 duration-200\">\n<span class=\"material-symbols-outlined text-stone-500\" data-icon=\"arrow_back\">arrow_back</span>\n</button>\n<h1 class=\"font-serif italic text-xl text-stone-900 dark:text-stone-50\">Trip Journal</h1>\n</div>\n<button class=\"flex items-center justify-center w-10 h-10 rounded-full bg-surface-container-high/50 hover:bg-surface-container-highest transition-colors active:scale-95\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"edit\">edit</span>\n</button>\n</header>\n<main class=\"relative min-h-screen pt-0 pb-24 md:pb-0 overflow-hidden\">\n<!-- Full Screen Hero Immersive Content -->\n<div class=\"absolute inset-0 z-0\">\n<img alt=\"Majestic Swiss Alps\" class=\"w-full h-full object-cover\" data-alt=\"cinematic wide angle shot of the swiss alps at sunrise with dramatic peaks covered in snow and soft morning mist in the valleys\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCulm-CbI0IkGAlMXW2yx_elx_AHU5xrz6jxMuHI5Go781usqwEkI0J4slzG2NOm641zpeOzNCnARXhOcyX7vd4OjE4V-BTwGqIx_hFwE7uqIX_np0V-5k1LiVtlUfIheh7VSFs-zvBdyuN9zTe7puGcjTsAbzYI2Y063a-yyaspj1fclfuyAcVYjn4skYGgkGFvvk2yXP9xVGzmf_Uc3pGfuLQjwvEPb5Cs2xXi8OR8so1KL0Nw0WcHrk9_vSFEjnWYa4GxO-gjLk\"/>\n<div class=\"absolute inset-0 hero-gradient\"></div>\n</div>\n<!-- Editorial Content Layout -->\n<div class=\"relative z-10 flex flex-col justify-end min-h-screen px-6 pb-32 md:pb-20 md:px-12 max-w-6xl mx-auto\">\n<div class=\"max-w-2xl animate-fade-in\">\n<!-- Location & Date Chips -->\n<div class=\"flex flex-wrap gap-3 mb-8\">\n<span class=\"glass-panel px-4 py-1.5 rounded-full text-on-surface text-[11px] font-medium tracking-widest uppercase flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-[16px]\" data-icon=\"location_on\">location_on</span>\n                        Switzerland\n                    </span>\n<span class=\"glass-panel px-4 py-1.5 rounded-full text-on-surface text-[11px] font-medium tracking-widest uppercase flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-[16px]\" data-icon=\"calendar_today\">calendar_today</span>\n                        July 12-24, 2026\n                    </span>\n</div>\n<!-- Main Headline -->\n<h2 class=\"font-headline text-5xl md:text-7xl lg:text-8xl text-white mb-6 leading-[1.1] tracking-tight\">\n                    Exploring the <span class=\"italic font-normal\">Swiss Alps</span>\n</h2>\n<!-- Pull Quote / Summary -->\n<div class=\"relative pl-6 mb-12 border-l-2 border-primary-fixed\">\n<p class=\"font-body text-white/90 text-lg md:text-xl leading-relaxed max-w-lg italic\">\n                        \"The mountains are calling and I must go. Discovering the quiet grandeur of the Matterhorn and the hidden lakes of Zermatt.\"\n                    </p>\n</div>\n<!-- Action Area -->\n<div class=\"flex flex-col sm:flex-row items-center gap-6\">\n<button class=\"w-full sm:w-auto px-10 py-5 bg-gradient-to-br from-primary to-primary-container text-on-primary rounded-xl font-bold tracking-wide text-sm flex items-center justify-center gap-3 shadow-lg active:scale-95 transition-transform\">\n                        OPEN JOURNAL\n                        <span class=\"material-symbols-outlined\" data-icon=\"menu_book\">menu_book</span>\n</button>\n<div class=\"flex items-center gap-4\">\n<div class=\"flex -space-x-3\">\n<img class=\"w-10 h-10 rounded-full border-2 border-white object-cover\" data-alt=\"portrait of a man with sunglasses in travel attire\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuARMQ-gZc8MFgx6Xtczh9CrIIyKAHALzMOrGgtMlqMVNjNh8ZmXpwnnqici-dDsn7nC-3f-_LTrb_wNHKD-ujXTRe4nLoOxbYESUNh0wMONz1i9dlxlR0yzAhsEFfCBcnPKJ1wZj1dChfhaqqjvREm1MIzEsPNIhBDtr0mWDn_eBlT12s3nZME-76CtYuHd6KinBhYAZmLIj_BhsFn45x3kba7rH-LURgs4n58gBcgg4IKamNpQnhb4BrONELnnKbe_pgwSmkFGt5g\"/>\n<img class=\"w-10 h-10 rounded-full border-2 border-white object-cover\" data-alt=\"portrait of a smiling woman with a sun hat\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuB310ZTWNfNqhTIh_yJB30MHUPzWzE_ArUzpP4A27agUKBbc89Qdop70z4f-t38JEDgO5yCOLgD9-KVdzPcK9snMi6k5yUsx8VhJNL-QTIleuKD9BseWQytZM5Q82B3EYWQyWppfEB0Ovye9vSIxm01ZE-htvipDD7gtI7MZIm_qirXNLv8-Elmb_OMF3gqEZVy_g1V5IXkiTer8g5_8D3L8ScY_eeegjOsI4S_QosMf5zsuM73cRSM8jqb4XadYO3CbgYWMvTSSWg\"/>\n<div class=\"w-10 h-10 rounded-full border-2 border-white bg-surface-container-highest flex items-center justify-center text-[10px] font-bold text-on-surface-variant\">\n                                +2\n                            </div>\n</div>\n<span class=\"text-white/80 text-xs font-medium uppercase tracking-widest\">Shared Trip</span>\n</div>\n</div>\n</div>\n</div>\n<!-- Decorative Elements -->\n<div class=\"absolute top-1/2 right-12 -translate-y-1/2 hidden lg:flex flex-col gap-12 z-10\">\n<div class=\"flex flex-col items-center gap-4\">\n<span class=\"[writing-mode:vertical-lr] text-white/40 uppercase tracking-[0.5em] text-[10px] font-bold\">Scroll Details</span>\n<div class=\"w-px h-24 bg-gradient-to-b from-white/40 to-transparent\"></div>\n</div>\n</div>\n</main>\n<!-- Bottom Navigation Shell (Mobile Only) -->\n<nav class=\"md:hidden fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 dark:bg-stone-900/80 backdrop-blur-xl rounded-t-3xl z-50 shadow-[0_-10px_40px_rgba(30,27,25,0.04)] no-line tonal-shift\">\n<a class=\"flex flex-col items-center justify-center text-orange-700 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20 rounded-xl px-3 py-1 active:scale-90 transition-transform\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"auto_stories\" style=\"font-variation-settings: 'FILL' 1;\">auto_stories</span>\n<span class=\"font-sans text-[11px] font-medium tracking-wide uppercase mt-1\">Feed</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-stone-400 dark:text-stone-500 px-3 py-1 hover:text-stone-900 dark:hover:text-stone-100 active:scale-90 transition-transform\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"search\">search</span>\n<span class=\"font-sans text-[11px] font-medium tracking-wide uppercase mt-1\">Search</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-stone-400 dark:text-stone-500 px-3 py-1 hover:text-stone-900 dark:hover:text-stone-100 active:scale-90 transition-transform\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"add_circle\">add_circle</span>\n<span class=\"font-sans text-[11px] font-medium tracking-wide uppercase mt-1\">New</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-stone-400 dark:text-stone-500 px-3 py-1 hover:text-stone-900 dark:hover:text-stone-100 active:scale-90 transition-transform\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-sans text-[11px] font-medium tracking-wide uppercase mt-1\">Profile</span>\n</a>\n</nav>\n<!-- Map Context Hint (Floating Bento Component) -->\n<div class=\"fixed right-6 bottom-32 md:bottom-12 z-20 hidden sm:block\">\n<div class=\"glass-panel p-4 rounded-2xl w-48 shadow-xl\">\n<div class=\"aspect-square w-full rounded-xl overflow-hidden mb-3 bg-stone-200\">\n<img alt=\"Map of Switzerland\" class=\"w-full h-full object-cover\" data-alt=\"stylized map showing swiss mountain topography with soft sepia and sage green tones\" data-location=\"Switzerland\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBxy5u6T93UvqHEY0o8dBoHef5UviiUuXFWzcRGMM7KcdrNonxtS9jYZ1FRRbaBpZzpClkQgdjDJfcDB3F8HT7I6Pg3d4xApHivh3Ryni0_1Mz3eHuCCmVM3Oz3NHJWGp-xvGf9qjaiJ2EtBOcnF7ZzWcPzkCoRJ5vUtr-vxJb2tpIXn-AhdPdqMC5MuWKrRzfAFRwXl2hDQIOkdlK0jg6c_nV6K-X97laVPCoYfriAHbfN0FYy0ctqYfnCHdl0sFewmC-jNgSWZlY\"/>\n</div>\n<div class=\"flex justify-between items-center\">\n<span class=\"text-[10px] font-bold uppercase tracking-wider text-on-surface-variant\">12 Locations</span>\n<span class=\"material-symbols-outlined text-primary text-sm\" data-icon=\"map\">map</span>\n</div>\n</div>\n</div>\n</body></html>"}
