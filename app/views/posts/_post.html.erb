<div id="<%= dom_id post %>" class="post-card ha-card p-6">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Post</p>
      <h3 class="mt-2 text-lg font-semibold text-[var(--ha-text)]"><%= post.title %></h3>
    </div>
    <span class="rounded-full border border-[var(--ha-border)] bg-[var(--ha-surface-muted)] px-3 py-1 text-xs font-medium text-[var(--ha-muted)]">#<%= post.id %></span>
  </div>

  <p class="mt-4 text-sm leading-relaxed text-[var(--ha-text)] opacity-80"><%= post.body %></p>

  <div class="mt-4 flex items-center gap-2 text-xs text-[var(--ha-muted)]">
    <span class="rounded-full bg-[var(--ha-surface-muted)] px-2 py-1">Author</span>
    <span class="font-semibold text-[var(--ha-text)]"><%= post.user.name %></span>
  </div>

  <% if action_name != "show" %>
    <div class="mt-5 flex flex-wrap gap-2">
      <%= link_to "View", post, class: "ha-button ha-button-secondary" %>
      <% if allowed_to?(:edit?, post) %>
        <%= link_to "Edit", edit_post_path(post), class: "ha-button ha-button-secondary" %>
      <% end %>
    </div>
  <% end %>
</div>
