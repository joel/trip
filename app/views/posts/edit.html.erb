<div class="space-y-6">
  <div>
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Posts</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Edit post</h1>
    <p class="mt-2 text-sm text-[var(--ha-muted)]">Refine the title, body, or owner.</p>
  </div>

  <div class="ha-card p-6">
    <%= render "form", post: @post %>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Back to posts", posts_path, class: "ha-button ha-button-secondary" %>
  </div>
</div>
