<div class="space-y-8">
  <div class="ha-card p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Access</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Sign in</h1>
    <p class="mt-3 text-sm text-[var(--ha-muted)]">Enter your email to choose a passkey or request a sign-in link.</p>
  </div>

  <%= render "flash" %>

  <div class="ha-card p-6 space-y-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Email</p>
      <h2 class="mt-2 text-lg font-semibold">Continue with email</h2>
      <p class="mt-2 text-sm text-[var(--ha-muted)]">We use your email to find available sign-in methods.</p>
    </div>

    <%= render "login_form" %>

    <%= render "login_form_footer" %>
  </div>
</div>
