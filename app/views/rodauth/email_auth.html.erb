<div class="space-y-8">
  <div class="ha-card p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Email link</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Finish signing in</h1>
    <p class="mt-3 text-sm text-[var(--ha-muted)]">Confirm your sign-in to continue.</p>
  </div>

  <%= render "flash" %>

  <div class="ha-card p-6">
    <%= form_with url: rodauth.email_auth_path, method: :post, data: { turbo: false } do |form| %>
      <%== rodauth.email_auth_additional_form_tags %>
      <%= form.submit rodauth.login_button, class: "ha-button ha-button-primary w-full" %>
    <% end %>
  </div>
</div>
