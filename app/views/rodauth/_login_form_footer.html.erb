<% unless rodauth.login_form_footer_links.empty? %>
  <div class="mt-4 border-t border-[var(--ha-border)] pt-4">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">More options</p>
    <div class="mt-2 flex flex-wrap gap-3 text-sm text-[var(--ha-muted)]">
      <% rodauth.login_form_footer_links.sort.each do |_, link, text| %>
        <%= link_to text, link, class: "text-[var(--ha-text)] hover:underline" %>
      <% end %>
    </div>
  </div>
<% end %>
