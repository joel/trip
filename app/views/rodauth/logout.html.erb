<div class="space-y-8">
  <div class="ha-card p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Account</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Sign out</h1>
    <p class="mt-3 text-sm text-[var(--ha-muted)]">Confirm to end this session.</p>
  </div>

  <%= render "flash" %>

  <div class="ha-card p-6">
    <%= form_with url: rodauth.logout_path, method: :post, data: { turbo: false }, class: "space-y-6" do |form| %>
      <%== rodauth.logout_additional_form_tags %>

      <% if rodauth.features.include?(:active_sessions) %>
        <label for="global-logout" class="flex items-center gap-3 text-sm text-[var(--ha-muted)]">
          <%= form.check_box rodauth.global_logout_param, id: "global-logout", class: "h-4 w-4", include_hidden: false %>
          <span><%= rodauth.global_logout_label %></span>
        </label>
      <% end %>

      <%= form.submit rodauth.logout_button, class: "ha-button ha-button-danger w-full" %>
    <% end %>
  </div>
</div>
