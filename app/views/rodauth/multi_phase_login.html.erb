<% login_value = params[rodauth.login_param] %>

<div class="space-y-8">
  <div class="ha-card p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Access</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Choose a sign-in method</h1>
    <p class="mt-3 text-sm text-[var(--ha-muted)]">
      Continue for <span class="font-semibold text-[var(--ha-text)]"><%= login_value %></span>.
    </p>
  </div>

  <%= render "flash" %>

  <div class="grid gap-4 md:grid-cols-2">
    <%== rodauth.render_multi_phase_login_forms %>
  </div>

  <div class="ha-card p-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm text-[var(--ha-muted)]">Need to use a different email?</p>
    <%= link_to "Start over", rodauth.login_path, class: "ha-button ha-button-secondary" %>
  </div>
</div>
