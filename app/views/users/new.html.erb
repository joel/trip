<div class="space-y-6">
  <div>
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Users</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">New user</h1>
    <p class="mt-2 text-sm text-[var(--ha-muted)]">Add someone who can own posts.</p>
  </div>

  <div class="ha-card p-6">
    <%= render "form", user: @user %>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Back to users", users_path, class: "ha-button ha-button-secondary" %>
  </div>
</div>
