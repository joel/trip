<div id="<%= dom_id user %>" class="ha-card p-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">User</p>
      <p class="mt-2 text-lg font-semibold text-[var(--ha-text)]"><%= user.name %></p>
      <div class="mt-3 flex items-center gap-2 text-xs text-[var(--ha-muted)]">
        <span class="rounded-full bg-[var(--ha-surface-muted)] px-2 py-1">Email</span>
        <span class="font-semibold text-[var(--ha-text)]"><%= user.email %></span>
      </div>
    </div>
    <span class="rounded-full border border-[var(--ha-border)] bg-[var(--ha-surface-muted)] px-3 py-1 text-xs font-medium text-[var(--ha-muted)]">#<%= user.id %></span>
  </div>

  <% if action_name != "show" %>
    <div class="mt-5 flex flex-wrap gap-2">
      <%= link_to "View", user, class: "ha-button ha-button-secondary" %>
      <% if allowed_to?(:edit?, user) %>
        <%= link_to "Edit", edit_user_path(user), class: "ha-button ha-button-secondary" %>
      <% end %>
    </div>
  <% end %>
</div>
