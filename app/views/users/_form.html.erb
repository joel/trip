<%= form_with(model: user, class: "space-y-6") do |form| %>
  <% if user.errors.any? %>
    <div id="error_explanation" class="ha-card border border-red-200 bg-red-50/80 px-4 py-3 text-sm text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-200">
      <h2 class="font-semibold"><%= pluralize(user.errors.count, "error") %> prohibited this user from being saved:</h2>

      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "text-sm font-semibold text-[var(--ha-muted)]" %>
    <%= form.text_field :name, class: "ha-input mt-2" %>
  </div>

  <div>
    <%= form.label :email, class: "text-sm font-semibold text-[var(--ha-muted)]" %>
    <%= form.email_field :email, class: "ha-input mt-2", autocomplete: "email" %>
  </div>

  <div>
    <span class="text-sm font-semibold text-[var(--ha-muted)]">Roles</span>
    <div class="mt-3 grid gap-2 sm:grid-cols-2">
      <%= form.collection_check_boxes :roles, User.roles_config, :to_s, :to_s do |box| %>
        <label class="flex items-center gap-2 rounded-xl border border-[var(--ha-border)] bg-[var(--ha-surface)] px-3 py-2 text-sm text-[var(--ha-text)]">
          <%= box.check_box class: "h-4 w-4 rounded border-[var(--ha-border)] text-[var(--ha-accent)] focus:ring-2 focus:ring-[var(--ha-accent)]" %>
          <span class="capitalize"><%= box.text.tr("_", " ") %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= form.submit class: "ha-button ha-button-primary" %>
  </div>
<% end %>
