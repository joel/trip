<%= form_with(model: user, url: account_path, class: "space-y-6") do |form| %>
  <% if user.errors.any? %>
    <div id="error_explanation" class="ha-card border border-red-200 bg-red-50/80 px-4 py-3 text-sm text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-200">
      <h2 class="font-semibold"><%= pluralize(user.errors.count, "error") %> prohibited this account from being saved:</h2>

      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "text-sm font-semibold text-[var(--ha-muted)]" %>
    <%= form.text_field :name, class: "ha-input mt-2" %>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= form.submit "Save changes", class: "ha-button ha-button-primary" %>
  </div>
<% end %>
