<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Catalyst" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Catalyst">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-[var(--ha-bg)] text-[var(--ha-text)] antialiased" data-controller="theme">
    <% if flash.any? %>
      <div class="pointer-events-none fixed right-6 top-6 z-50 flex w-full max-w-sm flex-col gap-3">
        <% flash.each do |type, message| %>
          <% if type.to_s == "notice" %>
            <div data-controller="toast" data-toast-timeout-value="4000" class="pointer-events-auto flex items-start gap-3 rounded-2xl border border-emerald-300/30 bg-[linear-gradient(140deg,rgba(16,185,129,0.12),rgba(15,23,42,0.92))] p-4 text-emerald-100 shadow-[0_18px_45px_-30px_rgba(16,185,129,0.6)] transition-all duration-300 ease-out">
              <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-400/20 text-emerald-200">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M6 10.5l2.3 2.3L14.5 6.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold">All set</p>
                <p class="mt-1 text-sm text-emerald-100/80"><%= message %></p>
              </div>
              <button type="button" data-action="toast#dismiss" class="flex h-7 w-7 items-center justify-center rounded-full text-emerald-100/80 transition hover:bg-emerald-200/10 hover:text-emerald-100" aria-label="Dismiss notification">
                <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M6 6l8 8M14 6l-8 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
              </button>
            </div>
          <% else %>
            <div data-controller="toast" data-toast-timeout-value="4500" class="pointer-events-auto flex items-start gap-3 rounded-2xl border border-rose-300/30 bg-[linear-gradient(140deg,rgba(244,63,94,0.12),rgba(15,23,42,0.92))] p-4 text-rose-100 shadow-[0_18px_45px_-30px_rgba(244,63,94,0.6)] transition-all duration-300 ease-out">
              <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-rose-400/20 text-rose-200">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M10 6v5M10 14.2v.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                  <circle cx="10" cy="10" r="6.8" stroke="currentColor" stroke-width="1.5" />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold">Action needed</p>
                <p class="mt-1 text-sm text-rose-100/80"><%= message %></p>
              </div>
              <button type="button" data-action="toast#dismiss" class="flex h-7 w-7 items-center justify-center rounded-full text-rose-100/80 transition hover:bg-rose-200/10 hover:text-rose-100" aria-label="Dismiss notification">
                <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M6 6l8 8M14 6l-8 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
              </button>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <div class="flex min-h-screen">
      <details class="ha-nav flex h-screen flex-shrink-0 flex-col overflow-hidden bg-[linear-gradient(180deg,var(--ha-panel),var(--ha-panel-strong))] text-[var(--ha-panel-text)] shadow-[18px_0_45px_-30px_rgba(15,23,42,0.7)]" open>
        <summary class="flex cursor-pointer items-center justify-between gap-3 px-4 pb-3 pt-4" aria-label="Toggle menu">
          <div class="ha-nav-brand flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-white/10 text-lg font-semibold text-white">
              S
            </div>
            <span class="ha-nav-label text-base font-semibold tracking-tight text-[var(--ha-panel-text)]">Catalyst</span>
          </div>
          <span class="ha-nav-toggle flex h-9 w-9 items-center justify-center rounded-xl bg-white/10 text-white/70">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M12 5l-5 5 5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </summary>

        <% nav_base = "ha-nav-item flex items-center gap-3 rounded-2xl px-3 py-2.5 text-sm font-medium text-[var(--ha-panel-muted)] transition hover:bg-white/10 hover:text-[var(--ha-panel-text)]" %>
        <% nav_active = "bg-white/15 text-[var(--ha-panel-text)] shadow-[inset_0_0_0_1px_rgba(255,255,255,0.08)]" %>
        <% home_active = current_page?(root_path) %>
        <% posts_active = controller_name == "posts" %>
        <% users_active = controller_name == "users" %>

        <div class="ha-nav-body flex h-full flex-1 flex-col">
          <div class="px-3">
            <div class="ha-nav-label mb-3 px-2 text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-[var(--ha-panel-muted)]">
              Main
            </div>
            <nav class="space-y-1">
              <%= link_to root_path, class: "#{nav_base} ha-rise #{nav_active if home_active}", style: "animation-delay: 40ms;", aria: { current: (home_active ? "page" : nil) } do %>
                <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M3 9.5L10 4l7 5.5V16a1 1 0 0 1-1 1h-4v-5H8v5H4a1 1 0 0 1-1-1V9.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="ha-nav-label">Overview</span>
              <% end %>

              <%= link_to posts_path, class: "#{nav_base} ha-rise #{nav_active if posts_active}", style: "animation-delay: 80ms;", aria: { current: (posts_active ? "page" : nil) } do %>
                <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M6 4h8M6 8h8M6 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    <rect x="3" y="3" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                </span>
                <span class="ha-nav-label">Posts</span>
              <% end %>

              <% if allowed_to?(:index?, User) %>
                <%= link_to users_path, class: "#{nav_base} ha-rise #{nav_active if users_active}", style: "animation-delay: 120ms;", aria: { current: (users_active ? "page" : nil) } do %>
                  <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M6.5 14.5c.9-1.3 2.2-2 3.5-2s2.6.7 3.5 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                      <circle cx="10" cy="7" r="3" stroke="currentColor" stroke-width="1.5" />
                      <rect x="3" y="3" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.5" />
                    </svg>
                  </span>
                  <span class="ha-nav-label">Users</span>
                <% end %>
              <% end %>
            </nav>
          </div>

          <div class="mt-auto px-3 pb-4 pt-6">
            <div class="border-t border-white/10 pt-4">
              <div class="ha-nav-label mb-3 px-2 text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-[var(--ha-panel-muted)]">
                Quick Actions
              </div>
              <div class="space-y-1">
                <% if allowed_to?(:new?, Post) %>
                  <%= link_to new_post_path, class: "#{nav_base} ha-rise", style: "animation-delay: 160ms;" do %>
                    <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                      </svg>
                    </span>
                    <span class="ha-nav-label">New post</span>
                  <% end %>
                <% end %>

                <% if allowed_to?(:new?, User) %>
                  <%= link_to new_user_path, class: "#{nav_base} ha-rise", style: "animation-delay: 200ms;" do %>
                    <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M10 5.5v9M5.5 10h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                      </svg>
                    </span>
                    <span class="ha-nav-label">New user</span>
                  <% end %>
                <% end %>

                <button type="button" class="ha-nav-item ha-rise flex w-full items-center gap-3 rounded-2xl px-3 py-2.5 text-sm font-medium text-[var(--ha-panel-muted)] transition hover:bg-white/10 hover:text-[var(--ha-panel-text)]" style="animation-delay: 240ms;" data-action="theme#toggle" aria-label="Toggle dark mode">
                  <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true" data-theme-target="iconLight">
                      <path d="M10 4V2M10 18v-2M4.7 4.7l1.4 1.4M13.9 13.9l1.4 1.4M2 10h2M16 10h2M4.7 15.3l1.4-1.4M13.9 6.1l1.4-1.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                      <circle cx="10" cy="10" r="3.2" stroke="currentColor" stroke-width="1.4" />
                    </svg>
                    <svg class="h-4 w-4 hidden" viewBox="0 0 20 20" fill="none" aria-hidden="true" data-theme-target="iconDark">
                      <path d="M14.8 12.8A6.2 6.2 0 0 1 7.2 5.2a6.8 6.8 0 1 0 7.6 7.6z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                    </svg>
                  </span>
                  <span class="ha-nav-label" data-theme-target="label">Dark mode</span>
                </button>

                <div class="mt-4 border-t border-white/10 pt-4">
                  <div class="ha-nav-label mb-3 px-2 text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-[var(--ha-panel-muted)]">
                    Account
                  </div>
                  <div class="space-y-1">
                    <% if rodauth.logged_in? %>
                      <%= link_to account_path, class: "#{nav_base} ha-rise", style: "animation-delay: 260ms;" do %>
                        <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <circle cx="10" cy="7" r="3" stroke="currentColor" stroke-width="1.5" />
                            <path d="M4.5 16.5c1-2.5 3.2-4 5.5-4s4.5 1.5 5.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                          </svg>
                        </span>
                        <span class="ha-nav-label">My account</span>
                      <% end %>

                      <%= link_to rodauth.webauthn_setup_path, class: "#{nav_base} ha-rise", style: "animation-delay: 300ms;" do %>
                        <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M5 9.5c0-2.5 2-4.5 5-4.5s5 2 5 4.5-2 4.5-5 4.5S5 12 5 9.5z" stroke="currentColor" stroke-width="1.5" />
                            <path d="M10 7v5M7.5 9.5h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                          </svg>
                        </span>
                        <span class="ha-nav-label">Add passkey</span>
                      <% end %>

                      <% if rodauth.webauthn_setup? %>
                        <%= link_to rodauth.webauthn_remove_path, class: "#{nav_base} ha-rise", style: "animation-delay: 340ms;" do %>
                          <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                              <path d="M6 10h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                              <rect x="3" y="3" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.5" />
                            </svg>
                          </span>
                          <span class="ha-nav-label">Manage passkeys</span>
                        <% end %>
                      <% end %>

                      <%= button_to rodauth.logout_path, method: :post, form: { class: "w-full" }, class: "#{nav_base} ha-rise w-full text-left", style: "animation-delay: 380ms;" do %>
                        <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M7 5h6a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            <path d="M8 10h8M12.5 6.5 16 10l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </span>
                        <span class="ha-nav-label">Sign out</span>
                      <% end %>
                    <% else %>
                      <%= link_to rodauth.login_path, class: "#{nav_base} ha-rise", style: "animation-delay: 300ms;" do %>
                        <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M7 5h6a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            <path d="M12.5 10H4M7.5 6.5 4 10l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </span>
                        <span class="ha-nav-label">Sign in</span>
                      <% end %>

                      <%= link_to rodauth.create_account_path, class: "#{nav_base} ha-rise", style: "animation-delay: 340ms;" do %>
                        <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">
                          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M10 5v10M5 10h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            <rect x="3" y="3" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.5" />
                          </svg>
                        </span>
                        <span class="ha-nav-label">Create account</span>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </details>

      <main class="relative flex-1 overflow-hidden">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute -right-32 -top-32 h-80 w-80 rounded-full bg-[var(--ha-accent)] opacity-20 blur-3xl"></div>
          <div class="absolute -bottom-20 left-12 h-72 w-72 rounded-full bg-[var(--ha-accent-2)] opacity-10 blur-3xl"></div>
        </div>

        <div class="relative px-6 py-8 sm:px-10">
          <div class="mx-auto max-w-5xl ha-fade-in">
            <%= yield %>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
