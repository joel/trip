<div class="space-y-8">
  <div class="ha-card p-8">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Catalyst Hub</p>
        <h1 class="mt-2 text-4xl font-semibold tracking-tight sm:text-5xl">Welcome home</h1>
        <p class="mt-3 text-sm text-[var(--ha-muted)]">Keep posts and people aligned with a clean, focused workspace.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "View posts", posts_path, class: "ha-button ha-button-primary" %>
        <% if allowed_to?(:index?, User) %>
          <%= link_to "View users", users_path, class: "ha-button ha-button-secondary" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <div class="ha-card p-6 ha-rise" style="animation-delay: 80ms;">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Posts</p>
      <h2 class="mt-2 text-2xl font-semibold">Share updates</h2>
      <p class="mt-3 text-sm text-[var(--ha-muted)]">Create and manage posts that keep your team in the loop.</p>
      <div class="mt-5 flex flex-wrap gap-2">
        <% if allowed_to?(:new?, Post) %>
          <%= link_to "New post", new_post_path, class: "ha-button ha-button-primary" %>
        <% end %>
        <%= link_to "Browse", posts_path, class: "ha-button ha-button-secondary" %>
      </div>
    </div>

    <% if allowed_to?(:index?, User) %>
      <div class="ha-card p-6 ha-rise" style="animation-delay: 160ms;">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Users</p>
        <h2 class="mt-2 text-2xl font-semibold">Stay connected</h2>
        <p class="mt-3 text-sm text-[var(--ha-muted)]">Manage who owns and contributes to the latest updates.</p>
        <div class="mt-5 flex flex-wrap gap-2">
          <%= link_to "New user", new_user_path, class: "ha-button ha-button-primary" %>
          <%= link_to "Browse", users_path, class: "ha-button ha-button-secondary" %>
        </div>
      </div>
    <% end %>

    <% if rodauth.logged_in? %>
      <div class="ha-card p-6 ha-rise" style="animation-delay: 240ms;">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Security</p>
        <h2 class="mt-2 text-2xl font-semibold">Add a passkey</h2>
        <p class="mt-3 text-sm text-[var(--ha-muted)]">Register a passkey per device for faster, safer sign-ins.</p>
        <div class="mt-5 flex flex-wrap gap-2">
          <%= link_to "Add passkey", rodauth.webauthn_setup_path, class: "ha-button ha-button-primary" %>
          <% if rodauth.webauthn_setup? %>
            <%= link_to "Manage passkeys", rodauth.webauthn_remove_path, class: "ha-button ha-button-secondary" %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="ha-card p-6 ha-rise" style="animation-delay: 240ms;">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ha-muted)]">Access</p>
        <h2 class="mt-2 text-2xl font-semibold">Sign in faster</h2>
        <p class="mt-3 text-sm text-[var(--ha-muted)]">Use a one-time email link or a passkey to access your workspace.</p>
        <div class="mt-5 flex flex-wrap gap-2">
          <%= link_to "Sign in", rodauth.login_path, class: "ha-button ha-button-primary" %>
          <%= link_to "Create account", rodauth.create_account_path, class: "ha-button ha-button-secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
