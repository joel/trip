<div class="mx-auto max-w-xl rounded-3xl border border-white/10 bg-[linear-gradient(140deg,var(--ha-panel),var(--ha-panel-strong))] p-8 text-[var(--ha-text)] shadow-[0_20px_60px_-45px_rgba(15,23,42,0.6)]">
  <h1 class="text-lg font-semibold tracking-tight">Sign in required</h1>
  <p class="mt-2 text-sm text-[var(--ha-muted)]">
    You need an account to perform that action.
  </p>
  <div class="mt-5 flex flex-wrap gap-3">
    <%= link_to "Sign in", rodauth.login_path, class: "ha-button ha-button-primary" %>
    <%= link_to "Create account", rodauth.create_account_path, class: "ha-button ha-button-secondary" %>
  </div>
</div>
